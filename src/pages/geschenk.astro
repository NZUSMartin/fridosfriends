---
/**
 * /geschenk — Geschenk (gift-voucher) — POSITIONING TEST (unlinked).
 * ROBUST approach: render the voucher on a <canvas> (image + text with explicit
 * pixel coords, textBaseline='top') — the SAME imperative drawing that was verified
 * correct. The canvas IS the preview; the download is that canvas wrapped in one A4 PDF.
 * No CSS-% positioning, no drawing onto the loaded template PDF. Option 3 = brand fonts.
 */
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
---
<Layout title="Geschenk (Test)" lang="de" path="/geschenk" spine="none">
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Geschenk · Positionierungs-Test" />
        <h1>Bildung, die Deinen Namen trägt.</h1>
        <p class="prose" style="color:var(--stone);margin-top:var(--sp-3)">
          Testseite (noch nicht verlinkt). Die Vorschau rechts ist eine Canvas-Zeichnung —
          exakt das, was heruntergeladen wird. Tippen, Betrag wählen, „Als PDF herunterladen".
        </p>
      </div>

      <div class="gk">
        <div class="gk__form" data-reveal>
          <label class="gk__fld"><span>Name des/der Beschenkten</span>
            <input type="text" id="f-recipient" placeholder="z. B. Pater Muster" /></label>
          <label class="gk__fld"><span>Welcher Geburtstag? (optional)</span>
            <input type="text" id="f-year" placeholder="z. B. 80." /></label>
          <label class="gk__fld"><span>Ihr Name</span>
            <input type="text" id="f-giver" placeholder="z. B. Sabine Beispiel" /></label>
          <span class="gk__lab">Betrag</span>
          <div class="gk__tiers" id="f-tiers"></div>
          <label class="gk__fld"><span>Oder freier Betrag (€)</span>
            <input type="text" id="f-free" inputmode="numeric" placeholder="z. B. 150" /></label>
          <button class="btn btn--primary" id="f-dl" style="width:100%;margin-top:var(--sp-4)">Als PDF herunterladen</button>
          <button class="btn" id="f-png" style="width:100%;margin-top:var(--sp-2)">Als Bild (PNG) herunterladen</button>
          <p id="f-status" class="gk__status"></p>
        </div>

        <div class="gk__previewcol" data-reveal>
          <p class="gk__plabel">Live-Vorschau (Canvas)</p>
          <canvas id="gk-canvas" class="gk__canvas"></canvas>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .gk { display:grid; grid-template-columns:1fr 1fr; gap:var(--sp-7); align-items:start; margin-top:var(--sp-6); }
  @media (max-width:820px){ .gk{ grid-template-columns:1fr; } }
  .gk__fld { display:block; margin-bottom:var(--sp-4); }
  .gk__fld span, .gk__lab { display:block; font-family:var(--font-sans); font-size:var(--step--1); font-weight:600; margin-bottom:var(--sp-2); }
  .gk__fld input { width:100%; font:inherit; font-size:var(--step-0); padding:.6em .75em; border:1px solid var(--line); border-radius:var(--r-input); background:#fff; color:var(--ink); }
  .gk__fld input:focus { outline:2px solid var(--teal); border-color:var(--teal); }
  .gk__tiers { display:grid; grid-template-columns:repeat(3,1fr); gap:var(--sp-2); margin-bottom:var(--sp-4); }
  .gk__tier { border:1px solid var(--line); background:#fff; border-radius:var(--r-card); padding:.6em .4em; text-align:center; cursor:pointer; font-family:var(--font-serif); font-weight:600; }
  .gk__tier.sel { border-color:var(--teal); background:var(--paper); }
  .gk__status { font-size:var(--step--1); color:var(--stone); margin-top:var(--sp-3); min-height:1.2em; }
  .gk__previewcol { position:sticky; top:16px; }
  .gk__plabel { font-family:var(--font-sans); font-size:var(--step--1); font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:var(--gold-text); text-align:center; margin-bottom:var(--sp-3); }
  .gk__canvas { display:block; width:100%; max-width:460px; height:auto; margin:0 auto; border-radius:var(--r-card); box-shadow:var(--shadow-lift); }
</style>

<script>
  const PAGE_W = 595.28, PAGE_H = 841.89;               // A4 in points (for PDF wrap)
  const IMG_W = 1054, IMG_H = 1492;                     // native template image size
  const SCALE = 2;                                      // canvas render scale (crisper text/print)
  const CW = IMG_W * SCALE, CH = IMG_H * SCALE;

  // ONE map. x/y = fraction of page (y = TOP of text). sizeFrac = fraction of width.
  // y = BASELINE fraction (text sits ON the line). Calibrated to the live render.
  const FIELDS = {
    recipient: { x:0.205, y:0.221, align:'left',   kind:'serif',    sizeFrac:0.0380, color:'gold' },
    year:      { x:0.30,  y:0.293, align:'center', kind:'serif',    sizeFrac:0.0252, color:'gold' },
    giverBody: { x:0.075, y:0.346, align:'left',   kind:'sansBold', sizeFrac:0.0329, color:'gold' },
    signature: { x:0.459, y:0.769, align:'center', kind:'serif',    sizeFrac:0.0329, color:'gold' },
    amount:    { x:0.865, y:0.653, align:'right',  kind:'sansBold', sizeFrac:0.0240, color:'gold' },
    date:      { x:0.75,  y:0.779, align:'left',   kind:'sans',     sizeFrac:0.0150, color:'ink' },
    footline:  { x:0.50,  y:0.745, align:'center', kind:'sans',     sizeFrac:0.0105, color:'grey' },
  };
  const COLORS = { gold:'rgb(200,150,43)', ink:'rgb(55,53,49)', grey:'rgb(120,116,107)' };
  const FONTDEF = { serif:'600 %PX% "Source Serif 4",Georgia,serif', sans:'400 %PX% "Inter",system-ui,sans-serif', sansBold:'600 %PX% "Inter",system-ui,sans-serif' };
  const FOOTLINE = 'Dies ist keine Spendenbescheinigung – bitte anfordern bei vorstand@fridosfriends.de';

  const state = { recipient:'', year:'', giver:'', amount:100 };
  const $ = (id) => document.getElementById(id);
  const euro = (n) => new Intl.NumberFormat('de-DE').format(n) + ' €';
  const today = () => new Date().toLocaleDateString('de-DE', { day:'numeric', month:'long', year:'numeric' });
  const canvas = $('gk-canvas'); canvas.width = CW; canvas.height = CH;
  const ctx = canvas.getContext('2d');
  const tmpl = new Image(); let tmplReady = false;
  tmpl.onload = () => { tmplReady = true; draw(); };
  tmpl.src = '/voucher/geschenk-preview.png';

  const TIERS = [25,50,100,200,800];
  const tc = $('f-tiers');
  TIERS.forEach((t) => {
    const el = document.createElement('div');
    el.className = 'gk__tier' + (t===100?' sel':''); el.textContent = t + ' €';
    el.onclick = () => { $('f-free').value=''; state.amount=t; [...tc.children].forEach(c=>c.classList.remove('sel')); el.classList.add('sel'); draw(); };
    tc.appendChild(el);
  });
  $('f-free').addEventListener('input', (e)=>{ const v=parseInt((e.target.value||'').replace(/\D/g,''),10); [...tc.children].forEach(c=>c.classList.remove('sel')); if(v){ state.amount=v; draw(); } });
  $('f-recipient').addEventListener('input',(e)=>{ state.recipient=e.target.value; draw(); });
  $('f-year').addEventListener('input',(e)=>{ state.year=e.target.value; draw(); });
  $('f-giver').addEventListener('input',(e)=>{ state.giver=e.target.value; draw(); });

  function textFor(k){
    if(k==='amount') return new Intl.NumberFormat('de-DE').format(state.amount); // number only — box has a printed €
    if(k==='date') return today();
    if(k==='footline') return FOOTLINE;
    if(k==='giverBody'||k==='signature') return state.giver || '';
    return state[k] || '';
  }
  function draw(){
    if(!tmplReady) return;
    ctx.clearRect(0,0,CW,CH);
    ctx.drawImage(tmpl, 0, 0, CW, CH);
    ctx.textBaseline = 'alphabetic';
    Object.keys(FIELDS).forEach((k)=>{
      const f = FIELDS[k]; const txt = textFor(k); if(!txt) return;
      const px = Math.round(f.sizeFrac * CW);
      ctx.font = FONTDEF[f.kind].replace('%PX%', px + 'px');
      ctx.textAlign = f.align; ctx.fillStyle = COLORS[f.color];
      ctx.fillText(txt, f.x*CW, f.y*CH);
    });
  }
  // wait for brand fonts before first paint, then draw
  async function ready(){
    try { await Promise.all([
      document.fonts.load('600 80px "Source Serif 4"'),
      document.fonts.load('600 40px "Inter"'),
      document.fonts.load('400 40px "Inter"'),
    ]); } catch(e){}
    draw();
  }
  ready();

  function dl(blob, name){ const u=URL.createObjectURL(blob); const a=document.createElement('a'); a.href=u; a.download=name; document.body.appendChild(a); a.click(); a.remove(); setTimeout(()=>URL.revokeObjectURL(u),4000); }

  $('f-png').addEventListener('click', ()=>{ draw(); canvas.toBlob((b)=>{ dl(b,'Fridos-Friends-Geschenk.png'); $('f-status').textContent='Fertig — Bild (PNG) heruntergeladen.'; }, 'image/png'); });

  $('f-dl').addEventListener('click', async ()=>{
    $('f-status').textContent = 'PDF wird erstellt …';
    try {
      draw();
      const png = await new Promise((res)=>canvas.toBlob(res,'image/png'));
      const bytes = new Uint8Array(await png.arrayBuffer());
      const { PDFDocument } = await import('pdf-lib');
      const pdf = await PDFDocument.create();                 // NEW doc — 1 page only
      const page = pdf.addPage([PAGE_W, PAGE_H]);
      const img = await pdf.embedPng(bytes);
      page.drawImage(img, { x:0, y:0, width:PAGE_W, height:PAGE_H });
      const out = await pdf.save();
      dl(new Blob([out], { type:'application/pdf' }), 'Fridos-Friends-Geschenk.pdf');
      $('f-status').textContent = 'Fertig — PDF (1 Seite) heruntergeladen.';
    } catch(err){ $('f-status').textContent = 'Fehler: ' + (err && err.message ? err.message : err); }
  });
</script>
