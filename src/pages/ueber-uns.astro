---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import PromiseBand from '../components/PromiseBand.astro';
import CTABand from '../components/CTABand.astro';

const betterplace = 'https://www.betterplace.org/de/projects/165916-schulstipendien-fuer-maedchen-in-uganda-bildung-ist-ihre-zukunft';

const board = [
  {
    name: 'Dominik Bartsch',
    role: 'Vorsitzender',
    body: 'Führt den Verein und hält die Verbindung zum Jesuit Refugee Service in Uganda. Er sorgt dafür, dass jede Entscheidung dem Satzungszweck dient: der Schulbildung von Mädchen in Adjumani.',
    email: null,
  },
  {
    name: 'Martin Hirt',
    role: 'Stellv. Vorsitzender',
    body: 'Vertritt den Vorsitzenden und begleitet die strategische Arbeit des Vorstands. Er bringt die Perspektive der Gründungsmitglieder ein und sorgt für eine transparente, ehrenamtliche Organisation.',
    email: null,
  },
  {
    name: 'Lorenz Dietsche',
    role: 'Schatzmeister',
    body: 'Verantwortet Finanzen, Mitgliedsbeiträge und Spendenquittungen. Er wacht über das 100-%-Versprechen — dass jeder gespendete Euro in Stipendien fließt und die Verwaltung privat getragen bleibt.',
    email: null,
  },
];

const facts = [
  { dt: 'Gegründet', dd: '15. August 2025' },
  { dt: 'Sitz', dd: 'Köln' },
  { dt: 'Registergericht', dd: 'Amtsgericht Köln' },
  { dt: 'Status', dd: 'Gemeinnützig anerkannt' },
  { dt: 'Satzungszweck', dd: 'Förderung der Schulbildung bedürftiger Kinder und Jugendlicher in Entwicklungsländern, insbesondere Uganda' },
];
---

<Layout title="Über uns" lang="de" path="/ueber-uns" spine="progress">

  <!-- (a) INTRO -->
  <section class="section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="Über uns" />
      <h1 data-reveal>Sieben Freunde. Eine Verantwortung.</h1>
      <p class="lead" style="margin-top:var(--sp-5)" data-reveal>
        Frido&rsquo;s Friends e.V. wurde am 15. August 2025 von sieben Freunden aus dem Kolleg
        St. Blasien gegründet — dem Abiturjahrgang 1985. Uns verbindet nicht nur die gemeinsame
        Schulzeit, sondern eine persönliche Verbindung zu Pater Frido Pflüger SJ und zu dem, wofür
        er gelebt hat: Bildung als Dienst an der Würde des Menschen.
      </p>
      <p class="prose" style="margin-top:var(--sp-5);color:var(--stone)" data-reveal>
        Wir sind bewusst klein geblieben — keine große NGO-Struktur, sondern ein schlanker,
        transparenter und effizienter Verein. Wer wir sind, ist überschaubar; was wir bewirken
        wollen, ist es nicht. Genau diese Klarheit erlaubt uns ein Versprechen, das größere
        Organisationen selten geben können.
      </p>
    </div>
  </section>

  <!-- (b) 100 % PROMISE BAND -->
  <PromiseBand lang="de" />

  <!-- (c) VORSTAND -->
  <section class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Vorstand" />
        <h2>Drei Personen, ein ehrenamtlicher Auftrag.</h2>
      </div>
      <div class="grid-3" data-reveal-group>
        {board.map((member) => (
          <article class="card" data-reveal>
            <h3>{member.name}</h3>
            <Eyebrow text={member.role} as="p" class="board__role" />
            <p style="color:var(--stone);margin-top:var(--sp-3)">{member.body}</p>
            {member.email && (
              <p style="margin-top:var(--sp-4)">
                <a class="link-tertiary" href={`mailto:${member.email}`}>{member.email}</a>
              </p>
            )}
          </article>
        ))}
      </div>

      <div class="card founders-more" data-reveal>
        <Eyebrow text="Weitere Gründungsmitglieder" />
        <ul class="founders-list">
          <li>Iara Behs</li>
          <li>Hartmut Müller-Gerbes</li>
          <li>Robert Schnekenbühl</li>
          <li>Dorothee Thum</li>
        </ul>
      </div>

      <p class="caption" style="margin-top:var(--sp-6);max-width:none" data-reveal>
        Sieben Freunde, fünf davon Abiturjahrgang 1985 des Kollegs St. Blasien. Der Vorstand arbeitet ehrenamtlich; Verwaltungskosten werden privat getragen.
      </p>
    </div>
  </section>

  <!-- (d) TRANSPARENZ + RECHTLICHES -->
  <section class="section">
    <div class="container container-text" data-reveal-group>
      <div class="section-head" data-reveal>
        <Eyebrow text="Transparenz & Rechtliches" />
        <h2>Was wir versprechen, können Sie überprüfen.</h2>
      </div>

      <p class="prose" style="color:var(--stone)" data-reveal>
        Einmal im Jahr legen wir einen Rechenschaftsbericht vor — offen, nachvollziehbar und
        ohne Beschönigung. Unser Satzungszweck ist die Förderung der Schulbildung bedürftiger
        Kinder und Jugendlicher in Entwicklungsländern, insbesondere in Uganda. Daran lassen
        wir uns messen.
      </p>

      <dl class="facts" data-reveal>
        {facts.map((f) => (
          <div class="facts__row">
            <dt>{f.dt}</dt>
            <dd>{f.dd}</dd>
          </div>
        ))}
      </dl>

      <p class="prose" style="color:var(--stone);margin-top:var(--sp-6)" data-reveal>
        Unsere Arbeit vor Ort geschieht nicht allein. Wir setzen das Werk von Pater Frido mit
        einem erfahrenen Partner um — dem Jesuit Refugee Service, der die Familien im Bezirk
        Adjumani kennt und die Stipendien begleitet.
      </p>
      <p style="margin-top:var(--sp-4)" data-reveal>
        <a class="link-tertiary" href="/versprechen">Wie wir das 100-%-Versprechen halten →</a>
      </p>
      <p style="margin-top:var(--sp-4)" data-reveal>
        <a class="link-tertiary" href="/projekt#jrs">Unseren Partner JRS kennenlernen →</a>
      </p>
    </div>
  </section>

  <!-- (e) CTA -->
  <CTABand
    eyebrow="Mitmachen"
    heading="Werden Sie Teil dieser Verantwortung."
    text="Als Mitglied geben Sie einem Mädchen Planungssicherheit über ein ganzes Schuljahr — 800 € tragen es vollständig."
    primaryHref="/mitmachen"
    primaryLabel="Mitmachen"
    secondaryHref={betterplace}
    secondaryLabel="Jetzt spenden"
  />

</Layout>

<style>
  /* Page-local layout only — uses existing design tokens (var(--...)). */
  .board__role { margin-top: var(--sp-3); margin-bottom: 0; }

  .facts {
    margin: var(--sp-6) 0 0;
    border-top: 1px solid var(--line);
  }
  .facts__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-1);
    padding: var(--sp-4) 0;
    border-bottom: 1px solid var(--line);
  }
  @media (min-width: 768px) {
    .facts__row {
      grid-template-columns: 220px 1fr;
      gap: var(--sp-5);
      align-items: baseline;
    }
  }
  .facts dt {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--stone);
  }
  .facts dd {
    margin: 0;
    color: var(--ink);
  }
</style>
