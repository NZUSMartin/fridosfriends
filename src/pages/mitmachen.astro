---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import MembershipForm from '../components/MembershipForm.astro';
import ProgressThermometer from '../components/ProgressThermometer.astro';
import { FUNDING, BETTERPLACE, BETTERPLACE_SHORT, PAYPAL_DONATE, PAYPAL_SUBSCRIBE } from '../consts';

const IBAN = 'DE44 6805 2230 0000 2055 26';

const trust = [
  {
    title: '100 % fließen in Stipendien',
    body: 'Verwaltungskosten tragen die Gründungsmitglieder privat — in der Satzung verankert.',
  },
  {
    title: 'Gemeinnützig anerkannt',
    body: 'Frido’s Friends e.V., eingetragen beim Amtsgericht Köln.',
  },
  {
    title: 'Jährlicher Rechenschaftsbericht',
    body: 'Wir legen offen, wie viele Mädchen gefördert werden und wohin jeder Euro geht.',
  },
  {
    title: 'Partner mit Schutzstandards',
    body: 'Vor Ort begleitet der Jesuit Refugee Service die Mädchen — mit klaren Schutzstandards.',
  },
  {
    title: 'Spendenquittung inklusive',
    body: 'Betterplace stellt Ihre Zuwendungsbestätigung automatisch aus.',
  },
  {
    title: 'Vorstand statt NGO-Apparat',
    body: 'Bewusst klein, transparent, effizient — keine große NGO-Struktur.',
  },
];
---

<Layout
  title="Mitmachen"
  description="Spenden Sie an Frido's Friends e.V. oder werden Sie Mitglied und finanzieren Sie ein Schuljahr für ein Mädchen in Norduganda. 100 % Ihrer Spende fließen in Stipendien."
  lang="de"
  path="/mitmachen"
  spine="progress"
>

  <!-- (1) INTRO -->
  <section class="section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="Mitmachen" />
      <h1 data-reveal>Ihre Unterstützung wirkt direkt.</h1>
      <p class="lead" style="margin-top:var(--sp-5)" data-reveal>
        100 % Ihrer Spende fließen direkt in Schulstipendien für Mädchen im Flüchtlingsbezirk
        Adjumani — die Verwaltungskosten tragen die Gründungsmitglieder privat. Kein Euro
        versickert. Sie entscheiden, wie Sie helfen: mit einer einmaligen Spende oder als
        Mitglied, Monat für Monat.
      </p>
    </div>
  </section>

  <!-- (2) FUNDING THERMOMETER -->
  <section class="section section--tight">
    <div class="container container-text">
      <div data-reveal>
        <ProgressThermometer
          lang="de"
          raised={FUNDING.raised}
          goal={FUNDING.goal}
          year={FUNDING.year}
          asof={FUNDING.asof}
          sheetUrl={FUNDING.sheetUrl}
        />
      </div>
    </div>
  </section>

  <!-- (3) SPENDEN — einmalig (FIRST) -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Spenden" />
        <h2>Jede Spende zählt — egal wie groß.</h2>
        <p class="give-lead" data-reveal>
          Zur Orientierung: Ein Schuljahr kostet rund 800 € pro Schülerin — aber jeder Beitrag
          hilft, auch kleine und regelmäßige.
        </p>
      </div>

      <div class="give-grid" data-reveal-group>
        <!-- One-time payment options -->
        <article class="card" data-reveal>
          <Eyebrow text="Online spenden" />
          <p style="color:var(--stone);margin:var(--sp-3) 0 var(--sp-5)">
            Schnell und sicher per PayPal oder betterplace.org. Jeder Betrag kommt unmittelbar an.
          </p>
          <div class="pay-row">
            <a class="btn btn--primary" href={PAYPAL_DONATE} rel="noopener" target="_blank">
              Mit PayPal spenden
            </a>
            <a class="pay-badge" href={PAYPAL_DONATE} rel="noopener" target="_blank" aria-label="PayPal">
              <img src="/images/paypal-logo.png" alt="PayPal" width="136" height="34" loading="lazy" />
            </a>
          </div>
          <div class="pay-row" style="margin-top:var(--sp-5)">
            <a class="btn btn--secondary" href={BETTERPLACE} rel="noopener" target="_blank">
              Mit betterplace spenden
            </a>
            <a class="pay-badge" href={BETTERPLACE_SHORT} rel="noopener" target="_blank" aria-label="betterplace.org">
              <img src="/images/betterplace-logo.png" alt="betterplace.org" width="128" height="19" loading="lazy" />
            </a>
          </div>
        </article>

        <!-- Direct bank transfer -->
        <article class="card" data-reveal>
          <Eyebrow text="Direkte Überweisung" />
          <p style="color:var(--stone);margin:var(--sp-3) 0 var(--sp-4)">
            Sie können auch direkt auf unser Vereinskonto überweisen:
          </p>
          <div class="bank-grid">
            <dl class="bank">
              <dt>Empfänger</dt>
              <dd>Frido’s Friends e.V.</dd>
              <dt>IBAN</dt>
              <dd>{IBAN}</dd>
              <dt>BIC</dt>
              <dd>SOLADES1STB</dd>
              <dt>Bank</dt>
              <dd>Sparkasse St. Blasien</dd>
              <dt>Verwendungszweck</dt>
              <dd>Spende Schulstipendien</dd>
            </dl>
            <figure class="figure bank-qr">
              <img
                src="/images/sepa-qr.png"
                alt="SEPA-QR-Code für eine Spende an Frido's Friends e.V."
                width="180" height="180"
                loading="lazy" decoding="async"
              />
              <p class="qr-note">
                Bitte E-Mail-Adresse nicht vergessen, wir würden Ihnen sehr gerne eine
                Spendenquittung zukommen lassen.
              </p>
            </figure>
          </div>
          <p class="caption" style="margin-top:var(--sp-5)">
            Für jede Spende stellen wir Ihnen auf Wunsch eine Spendenquittung aus; bis 300 € genügt
            dem Finanzamt der Kontoauszug.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- (4) MITGLIED WERDEN — regelmäßig (SECOND, equal weight) + (5) TRUST CLUSTER -->
  <section class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Mitglied werden" />
        <h2>Mitglied werden — regelmäßig fördern.</h2>
        <p class="give-lead" data-reveal>
          Eine Mitgliedschaft gibt uns Planungssicherheit: Aus Ihrer Unterstützung wird eine
          verlässliche Förderung, auf die wir Jahr für Jahr bauen können.
        </p>
      </div>

      <div class="join-grid">
        <!-- Ask column: real membership application form (Netlify → Vorstand) -->
        <div class="join-ask" data-reveal-group>
          <div data-reveal>
            <MembershipForm lang="de" />
          </div>

          <!-- Recurring options -->
          <div class="card" data-reveal>
            <Eyebrow text="Regelmäßig fördern" />
            <h3 class="h4" style="margin-top:var(--sp-3)">SEPA-Dauerauftrag</h3>
            <p style="color:var(--stone);margin-top:var(--sp-2)">
              Richten Sie bei Ihrer Bank einen Dauerauftrag auf unser Konto ein (z. B. 25 / 50 / 75 €
              monatlich), Verwendungszweck „Mitgliedsbeitrag“ — so einfach wird aus Ihrer Spende eine
              verlässliche Förderung.
            </p>
            <dl class="bank" style="margin-top:var(--sp-4)">
              <dt>Empfänger</dt>
              <dd>Frido’s Friends e.V.</dd>
              <dt>IBAN</dt>
              <dd>{IBAN}</dd>
              <dt>BIC</dt>
              <dd>SOLADES1STB</dd>
              <dt>Verwendungszweck</dt>
              <dd>Mitgliedsbeitrag</dd>
            </dl>

            <h3 class="h4" style="margin-top:var(--sp-6)">PayPal</h3>
            {PAYPAL_SUBSCRIBE ? (
              <a class="btn btn--primary" style="margin-top:var(--sp-3)" href={PAYPAL_SUBSCRIBE} rel="noopener" target="_blank">
                Monatlich mit PayPal
              </a>
            ) : (
              <p class="caption" style="margin-top:var(--sp-3)">PayPal-Abo folgt in Kürze.</p>
            )}

            <p class="caption" style="margin-top:var(--sp-5)">
              <a class="link-tertiary" href="/versprechen">Wie wir das 100-%-Versprechen halten →</a>
            </p>
          </div>
        </div>

        <!-- Trust cluster, ask-adjacent -->
        <aside class="card join-trust" aria-label="Vertrauen und Transparenz" data-reveal>
          <Eyebrow text="Warum Sie uns vertrauen können" />
          <ul class="join-trust__list">
            {trust.map((t) => (
              <li>
                <h3 class="h4">{t.title}</h3>
                <p>{t.body}</p>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- (4b) VERSCHENKEN -->
  <section class="band band-pure section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="Verschenken" />
      <h2 data-reveal>Schenken Sie Bildung — im Namen eines Menschen.</h2>
      <p class="prose" style="margin-top:var(--sp-4);color:var(--stone)" data-reveal>
        Verschenken Sie eine Spende in Ihrem Namen und gestalten Sie einen persönlichen
        Geschenk-Vordruck zum Ausdrucken — zum Geburtstag oder einfach, um Danke zu sagen.
        100&nbsp;% fließen in Stipendien.
      </p>
      <p style="margin-top:var(--sp-5)" data-reveal>
        <a class="btn btn--secondary" href="/geschenk">Geschenk gestalten</a>
      </p>
    </div>
  </section>

  <!-- (5) WEITERE MÖGLICHKEITEN ZU HELFEN -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Mehr als spenden" />
        <h2>Weitere Möglichkeiten zu helfen.</h2>
      </div>

      <div class="grid-3" data-reveal-group>
        <article class="card card--story" data-reveal>
          <h3>Weiterempfehlen</h3>
          <p style="color:var(--stone);margin-top:var(--sp-3)">
            Erzählen Sie von Frido’s Friends — in Ihrer Familie, im Freundeskreis, in Ihrer
            Gemeinde. Eine persönliche Empfehlung öffnet mehr Türen als jede Anzeige.
          </p>
        </article>

        <article class="card card--story" data-reveal>
          <h3>Netzwerk einbringen</h3>
          <p style="color:var(--stone);margin-top:var(--sp-3)">
            Sie kennen Menschen oder Unternehmen, die Mädchenbildung fördern möchten? Bringen
            Sie uns zusammen. Schreiben Sie an
            <a class="link-tertiary" href="mailto:vorstand@fridosfriends.de">vorstand@fridosfriends.de</a>.
          </p>
        </article>

        <article class="card card--story" data-reveal>
          <h3>Newsletter</h3>
          <p style="color:var(--stone);margin-top:var(--sp-3)">
            Bleiben Sie nah dran: Wir berichten, wie es den geförderten Mädchen geht. Melden Sie
            sich per E-Mail an unter
            <a class="link-tertiary" href="mailto:vorstand@fridosfriends.de?subject=Newsletter">vorstand@fridosfriends.de</a>.
          </p>
        </article>
      </div>
    </div>
  </section>

</Layout>

<style>
  .section--tight { padding-top: 0; }

  .give-lead {
    color: var(--stone);
    font-size: var(--step-0);
    margin-top: var(--sp-3);
  }

  /* Spenden: online options beside bank transfer */
  .give-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    align-items: start;
  }
  @media (min-width: 768px) {
    .give-grid { grid-template-columns: 1fr 1fr; gap: var(--sp-7); }
  }

  /* Membership ask beside the trust cluster — page-local layout only */
  .join-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .join-grid { grid-template-columns: 1.15fr 0.85fr; gap: var(--sp-8); }
  }
  .join-ask > * + * { margin-top: var(--sp-6); }

  .join-trust__list {
    list-style: none;
    margin: var(--sp-2) 0 0;
    padding: 0;
    display: grid;
    gap: var(--sp-5);
  }
  .join-trust__list li { max-width: none; }
  .join-trust__list p { color: var(--stone); margin-top: var(--sp-1); }

  .bank-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    align-items: start;
  }
  @media (min-width: 480px) {
    .bank-grid { grid-template-columns: 1fr auto; }
  }
  .bank-grid .bank { margin: 0; }
  .bank {
    font-size: var(--step-0);
    line-height: 1.6;
  }
  .bank dt {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--stone);
  }
  .bank dd {
    margin: 0 0 var(--sp-4);
    color: var(--ink);
  }
  .bank dd:last-child { margin-bottom: 0; }
  .bank-qr { text-align: center; }
  .bank-qr img {
    width: 180px;
    max-width: 100%;
    height: auto;
    border-radius: var(--r-card);
    border: 1px solid var(--line);
    background: var(--paper-pure);
  }
</style>
