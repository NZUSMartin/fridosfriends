---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Mitmachen" lang="de" currentPath="/mitmachen">

  <section style="padding:4rem 1.5rem 2rem;max-width:860px;margin:0 auto;text-align:center;">
    <p style="color:var(--gold);font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.5rem;">Mitmachen</p>
    <h1 style="font-family:'Source Serif 4',Georgia,serif;font-size:clamp(2rem,4vw,2.8rem);font-weight:700;color:var(--ink);margin:0 0 1rem;">Ihre Spende wirkt direkt.</h1>
    <p style="color:var(--stone);font-size:1.05rem;line-height:1.8;max-width:560px;margin:0 auto;">100 % Ihrer Spende fließt in Stipendien.</p>
  </section>

  <section style="padding:2rem 1.5rem 4rem;background:var(--paper-pure);">
    <div style="max-width:640px;margin:0 auto;">

      <div style="display:flex;gap:0;margin-bottom:2rem;border:1px solid var(--line);border-radius:8px;overflow:hidden;">
        <button id="btn-monthly" onclick="setFrequency('monthly')"
          style="flex:1;padding:12px;font-weight:600;font-size:0.95rem;border:none;cursor:pointer;background:var(--teal);color:#fff;">
          Monatlich
        </button>
        <button id="btn-yearly" onclick="setFrequency('yearly')"
          style="flex:1;padding:12px;font-weight:600;font-size:0.95rem;border:none;cursor:pointer;background:var(--paper);color:var(--ink);">
          Jährlich
        </button>
      </div>

      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;margin-bottom:2rem;">
        {[25, 75, 150, 300].map(amount => (
          <button
            id={`btn-${amount}`}
            onclick={`setAmount(${amount})`}
            style={`padding:14px;font-size:1rem;font-weight:700;border-radius:8px;cursor:pointer;${amount === 75 ? 'background:var(--teal);color:#fff;border:2px solid var(--teal);' : 'background:var(--paper);color:var(--ink);border:2px solid var(--line);'}`}>
            € {amount}
          </button>
        ))}
      </div>

      <div id="impact-box" style="background:var(--paper);border-radius:10px;padding:1.5rem;border:1px solid var(--line);margin-bottom:2rem;text-align:center;">
        <p style="color:var(--gold);font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin:0 0 0.5rem;">Ihre Wirkung</p>
        <p id="impact-text" style="font-family:'Source Serif 4',Georgia,serif;font-size:1.2rem;font-weight:600;color:var(--ink);margin:0;line-height:1.5;">
          € 75 / Monat finanziert ein vollständiges Stipendium für ein Schuljahr.
        </p>
      </div>

      <div style="background:var(--paper);border-radius:10px;padding:2rem;border:1px solid var(--line);margin-bottom:2rem;">
        <h3 style="font-family:'Source Serif 4',Georgia,serif;font-size:1.2rem;font-weight:700;color:var(--ink);margin:0 0 1.5rem;">Bankverbindung</h3>
        <table style="width:100%;border-collapse:collapse;font-size:0.95rem;">
          <tr style="border-bottom:1px solid var(--line);"><td style="padding:10px 0;color:var(--stone);font-size:0.85rem;width:40%;">Empfänger</td><td style="padding:10px 0;font-weight:600;">Frido's Friends e.V.</td></tr>
          <tr style="border-bottom:1px solid var(--line);"><td style="padding:10px 0;color:var(--stone);font-size:0.85rem;">IBAN</td><td style="padding:10px 0;font-weight:600;">DE44 6805 2230 0000 2055 26</td></tr>
          <tr style="border-bottom:1px solid var(--line);"><td style="padding:10px 0;color:var(--stone);font-size:0.85rem;">BIC</td><td style="padding:10px 0;font-weight:600;">SOLADES1STB</td></tr>
          <tr style="border-bottom:1px solid var(--line);"><td style="padding:10px 0;color:var(--stone);font-size:0.85rem;">Bank</td><td style="padding:10px 0;font-weight:600;">Sparkasse Bodensee-Hegau</td></tr>
          <tr><td style="padding:10px 0;color:var(--stone);font-size:0.85rem;">Verwendungszweck</td><td style="padding:10px 0;font-weight:600;">Spende Stipendien Uganda</td></tr>
        </table>
      </div>

      <div style="text-align:center;background:var(--paper);border-radius:10px;padding:2rem;border:1px solid var(--line);">
        <p style="color:var(--stone);font-size:0.9rem;margin:0 0 1rem;">SEPA-QR-Code — einfach scannen und überweisen</p>
        <img src="/images/sepa-qr.svg" alt="SEPA QR-Code für Spende an Frido's Friends e.V." style="width:180px;height:180px;display:inline-block;" />
      </div>

    </div>
  </section>

  <script>
    let currentFrequency = 'monthly';
    let currentAmount = 75;

    const impactMap = {
      monthly: {
        25: '€ 25 / Monat — das sind € 300 im Jahr: ein Drittel eines Stipendiums.',
        75: '€ 75 / Monat finanziert ein vollständiges Stipendium für ein Schuljahr.',
        150: '€ 150 / Monat — Sie finanzieren zwei Stipendien vollständig.',
        300: '€ 300 / Monat — vier Mädchen erhalten ein vollständiges Schuljahr.',
      },
      yearly: {
        25: '€ 25 einmalig — ein wichtiger Beitrag zu unserem Stipendienfonds.',
        75: '€ 75 einmalig — das ist ein Drittel eines Jahresstipendiums.',
        150: '€ 150 einmalig — fast die Hälfte der Schulgebühren für ein Mädchen.',
        300: '€ 300 einmalig — ein Drittel eines vollständigen Stipendiums.',
      },
    };

    function setFrequency(freq) {
      currentFrequency = freq;
      document.getElementById('btn-monthly').style.background = freq === 'monthly' ? 'var(--teal)' : 'var(--paper)';
      document.getElementById('btn-monthly').style.color = freq === 'monthly' ? '#fff' : 'var(--ink)';
      document.getElementById('btn-yearly').style.background = freq === 'yearly' ? 'var(--teal)' : 'var(--paper)';
      document.getElementById('btn-yearly').style.color = freq === 'yearly' ? '#fff' : 'var(--ink)';
      updateImpact();
    }

    function setAmount(amount) {
      currentAmount = amount;
      [25, 75, 150, 300].forEach(a => {
        const btn = document.getElementById('btn-' + a);
        if (btn) {
          btn.style.background = a === amount ? 'var(--teal)' : 'var(--paper)';
          btn.style.color = a === amount ? '#fff' : 'var(--ink)';
          btn.style.borderColor = a === amount ? 'var(--teal)' : 'var(--line)';
        }
      });
      updateImpact();
    }

    function updateImpact() {
      const el = document.getElementById('impact-text');
      if (el) el.textContent = impactMap[currentFrequency][currentAmount];
    }
  </script>

</Layout>
