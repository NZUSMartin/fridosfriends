---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import MembershipCalculator from '../components/MembershipCalculator.astro';

const betterplace = 'https://www.betterplace.org/de/projects/165916-schulstipendien-fuer-maedchen-in-uganda-bildung-ist-ihre-zukunft';

const trust = [
  {
    title: '100 % fließen in Stipendien',
    body: 'Verwaltungskosten tragen die Gründungsmitglieder privat — in der Satzung verankert.',
  },
  {
    title: 'Gemeinnützig anerkannt',
    body: 'Frido’s Friends e.V., eingetragen beim Amtsgericht Köln.',
  },
  {
    title: 'Jährlicher Rechenschaftsbericht',
    body: 'Wir legen offen, wie viele Mädchen gefördert werden und wohin jeder Euro geht.',
  },
  {
    title: 'Partner mit Schutzstandards',
    body: 'Vor Ort begleitet der Jesuit Refugee Service die Mädchen — mit klaren Schutzstandards.',
  },
  {
    title: 'Spendenquittung inklusive',
    body: 'Betterplace stellt Ihre Zuwendungsbestätigung automatisch aus.',
  },
  {
    title: 'Vorstand statt NGO-Apparat',
    body: 'Bewusst klein, transparent, effizient — keine große NGO-Struktur.',
  },
];
---

<Layout
  title="Mitmachen"
  description="Werden Sie Mitglied bei Frido's Friends e.V. und finanzieren Sie ein Schuljahr für ein Mädchen in Norduganda. 100 % Ihrer Spende fließen in Stipendien."
  lang="de"
  path="/mitmachen"
  spine="progress"
>

  <!-- (a) INTRO -->
  <section class="section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="Mitmachen" />
      <h1 data-reveal>Ihre Unterstützung wirkt direkt.</h1>
      <p class="lead" style="margin-top:var(--sp-5)" data-reveal>
        100 % Ihrer Spende fließen direkt in Schulstipendien für Mädchen im Flüchtlingsbezirk
        Adjumani — die Verwaltungskosten tragen die Gründungsmitglieder privat. Kein Euro
        versickert. Sie entscheiden, wie Sie helfen: als Mitglied Monat für Monat, mit einer
        einmaligen Spende oder per Überweisung.
      </p>
    </div>
  </section>

  <!-- (b)+(c) MEMBERSHIP (dominant) + TRUST CLUSTER -->
  <section class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Mitglied werden" />
        <h2>Eine Mitgliedschaft trägt ein ganzes Schuljahr.</h2>
      </div>

      <div class="join-grid">
        <!-- Ask column: calculator + dominant primary CTA -->
        <div class="join-ask" data-reveal-group>
          <div data-reveal>
            <MembershipCalculator lang="de" ctaHref={betterplace} />
          </div>

          <div class="join-cta" data-reveal>
            <p class="caption join-cta__note">
              Der Button führt zu betterplace.org, wo Sie Ihre Mitgliedschaft abschließen.
              Betterplace stellt Ihre Spendenquittung (Zuwendungsbestätigung) automatisch aus.
            </p>
            <p class="caption">
              Hinweis: Der satzungsgemäße Mindestbeitrag beträgt 50 €/Jahr und ist separat möglich.
            </p>
          </div>
        </div>

        <!-- Trust cluster, ask-adjacent -->
        <aside class="card join-trust" aria-label="Vertrauen und Transparenz" data-reveal>
          <Eyebrow text="Warum Sie uns vertrauen können" />
          <ul class="join-trust__list">
            {trust.map((t) => (
              <li>
                <h3 class="h4">{t.title}</h3>
                <p>{t.body}</p>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- (d)+(e) EINMALSPENDE + BANK TRANSFER -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Andere Wege zu spenden" />
        <h2>Lieber einmalig oder per Überweisung?</h2>
      </div>

      <div class="give-grid" data-reveal-group>
        <!-- (d) Einmalspende -->
        <article class="card" data-reveal>
          <Eyebrow text="Einmalspende" />
          <p class="give-amount"><b>900 €</b> = ein ganzes Schuljahr.</p>
          <p style="color:var(--stone)">
            Schulgebühren, Schulmaterialien, Hygieneartikel inklusive Menstruationsprodukte,
            das Internat und die Begleitung vor Ort — ein einziger Betrag, der ein Jahr trägt.
            Jeder Beitrag hilft, ob groß oder klein.
          </p>
          <a class="btn btn--secondary give-card__btn" href={betterplace} rel="noopener" target="_blank">
            Einmalig spenden über betterplace.org
          </a>
        </article>

        <!-- (e) Direct bank transfer -->
        <article class="card" data-reveal>
          <Eyebrow text="Direkte Überweisung" />
          <p style="color:var(--stone);margin-bottom:var(--sp-4)">
            Sie können auch direkt auf unser Vereinskonto überweisen:
          </p>
          <div class="bank-grid">
            <dl class="bank">
              <dt>Empfänger</dt>
              <dd>Frido’s Friends e.V.</dd>
              <dt>IBAN</dt>
              <dd>DE44 6805 2230 0000 2055 26</dd>
              <dt>BIC</dt>
              <dd>SOLADES1STB</dd>
              <dt>Bank</dt>
              <dd>Sparkasse St. Blasien</dd>
              <dt>Verwendungszweck</dt>
              <dd>Spende Schulstipendien</dd>
            </dl>
            <figure class="figure bank-qr">
              <img
                src="/images/sepa-qr.svg"
                alt="SEPA-QR-Code für eine Spende an Frido's Friends e.V."
                width="180" height="180"
                loading="lazy" decoding="async"
              />
              <figcaption>SEPA-QR-Code zum Einscannen</figcaption>
            </figure>
          </div>
          <p class="caption" style="margin-top:var(--sp-5)">
            Bis 300 € genügt der Kontoauszug als Spendennachweis. Darüber stellen wir Ihnen
            gerne eine Zuwendungsbestätigung aus — schreiben Sie uns an
            <a class="link-tertiary" href="mailto:martin.hirt@cassandra.ceo">martin.hirt@cassandra.ceo</a>.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- (f) WEITERE MÖGLICHKEITEN ZU HELFEN -->
  <section class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Mehr als spenden" />
        <h2>Weitere Möglichkeiten zu helfen.</h2>
      </div>

      <div class="grid-3" data-reveal-group>
        <article class="card card--story" data-reveal>
          <h3>Weiterempfehlen</h3>
          <p style="color:var(--stone);margin-top:var(--sp-3)">
            Erzählen Sie von Frido’s Friends — in Ihrer Familie, im Freundeskreis, in Ihrer
            Gemeinde. Eine persönliche Empfehlung öffnet mehr Türen als jede Anzeige.
          </p>
        </article>

        <article class="card card--story" data-reveal>
          <h3>Netzwerk einbringen</h3>
          <p style="color:var(--stone);margin-top:var(--sp-3)">
            Sie kennen Menschen oder Unternehmen, die Mädchenbildung fördern möchten? Bringen
            Sie uns zusammen. Schreiben Sie an
            <a class="link-tertiary" href="mailto:martin.hirt@cassandra.ceo">martin.hirt@cassandra.ceo</a>.
          </p>
        </article>

        <article class="card card--story" data-reveal>
          <h3>Newsletter</h3>
          <p style="color:var(--stone);margin-top:var(--sp-3)">
            Bleiben Sie nah dran: Wir berichten, wie es den geförderten Mädchen geht. Melden Sie
            sich per E-Mail an unter
            <a class="link-tertiary" href="mailto:martin.hirt@cassandra.ceo?subject=Newsletter">martin.hirt@cassandra.ceo</a>.
          </p>
        </article>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Membership ask (calculator + CTA) beside the trust cluster — page-local layout only */
  .join-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .join-grid { grid-template-columns: 1.15fr 0.85fr; gap: var(--sp-8); }
  }
  .join-ask > * + * { margin-top: var(--sp-6); }

  .join-cta { text-align: center; }
  .join-cta__btn { width: 100%; }
  .join-cta__note { margin-top: var(--sp-4); }

  .join-trust__list {
    list-style: none;
    margin: var(--sp-2) 0 0;
    padding: 0;
    display: grid;
    gap: var(--sp-5);
  }
  .join-trust__list li { max-width: none; }
  .join-trust__list p { color: var(--stone); margin-top: var(--sp-1); }

  /* Einmalspende + bank-transfer cards */
  .give-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    align-items: start;
  }
  @media (min-width: 768px) {
    .give-grid { grid-template-columns: 1fr 1fr; gap: var(--sp-7); }
  }
  .give-amount {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: var(--step-2);
    color: var(--ink);
    margin: var(--sp-2) 0 var(--sp-4);
  }
  .give-amount b { color: var(--gold); font-weight: 600; }
  .give-card__btn { margin-top: var(--sp-5); }

  .bank-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    align-items: start;
  }
  @media (min-width: 480px) {
    .bank-grid { grid-template-columns: 1fr auto; }
  }
  .bank-grid .bank { margin: 0; }
  .bank {
    font-size: var(--step-0);
    line-height: 1.6;
  }
  .bank dt {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--stone);
  }
  .bank dd {
    margin: 0 0 var(--sp-4);
    color: var(--ink);
  }
  .bank dd:last-child { margin-bottom: 0; }
  .bank-qr { text-align: center; }
  .bank-qr img {
    width: 180px;
    max-width: 100%;
    height: auto;
    border-radius: var(--r-card);
    border: 1px solid var(--line);
    background: var(--paper-pure);
  }
</style>
