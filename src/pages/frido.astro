---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import CTABand from '../components/CTABand.astro';

// Timeline — IMMUTABLE FACTS, verbatim chronology (1947 → 19./20. Juni 2021).
const timeline = [
  {
    year: '1947',
    heading: 'Geboren in Albbruck',
    body: 'Frido Pflüger kommt in Albbruck in Baden-Württemberg zur Welt.',
  },
  {
    year: '1966',
    heading: 'Eintritt in den Jesuitenorden',
    body: 'Mit der Aufnahme bei den Jesuiten beginnt ein Leben im Dienst — geprägt von Bildung und gelebter Nähe zum Menschen.',
  },
  {
    year: '1970er',
    heading: 'Studium und Lehrer am Kolleg St. Blasien',
    body: 'Nach seinen Studien wird Frido Lehrer am Kolleg St. Blasien — dort, wo Jahrzehnte später sieben seiner Schüler sein Werk fortführen werden.',
  },
  {
    year: '1980er',
    heading: 'Stellvertretender Schulleiter — und Aufbau in Dresden',
    body: 'Als stellvertretender Schulleiter am Kolleg St. Blasien prägt er eine ganze Generation. Im selben Jahrzehnt baut er das St.-Benno-Gymnasium in Dresden wieder auf.',
  },
  {
    year: '1986/87',
    heading: 'Philippinische Flüchtlingslager',
    body: 'In den Flüchtlingslagern der Philippinen begegnet Frido erstmals der Aufgabe, die sein weiteres Leben bestimmen wird: Bildung für Menschen auf der Flucht.',
  },
  {
    year: '2003–2006',
    heading: 'Erster Einsatz in Adjumani',
    body: 'In Adjumani in Norduganda baut Frido mit dem Jesuit Refugee Service (JRS) Bildungsprogramme auf — derselbe Ort, dieselbe Aufgabe, der unser Verein bis heute verpflichtet ist.',
  },
  {
    year: '2008–2012',
    heading: 'JRS-Regionaldirektor Ostafrika',
    body: 'Als Regionaldirektor des Jesuit Refugee Service für Ostafrika trägt Frido Verantwortung weit über eine einzelne Schule hinaus.',
  },
  {
    year: '2018',
    heading: 'JRS-Landesdirektor Uganda',
    body: 'Als Country Director des Jesuit Refugee Service in Uganda kehrt Frido in das Land zurück, dem über fünfzehn Jahre seines Wirkens für Mädchenbildung gegolten haben.',
  },
  {
    year: '19./20. Juni 2021',
    heading: 'Gestorben in Kampala',
    body: 'Pater Frido Pflüger SJ stirbt in der Nacht vom 19. auf den 20. Juni 2021 in Kampala. Was er begann, sollte nicht enden.',
  },
];
---

<Layout
  title="Pater Frido Pflüger SJ"
  description="Pater Frido Pflüger SJ (1947–2021) — Jesuit, Lehrer und schließlich JRS-Landesdirektor in Uganda. Über fünfzehn Jahre für Mädchenbildung in Adjumani. Dieser Verein trägt seinen Namen als Versprechen."
  lang="de"
  path="/frido"
  spine="fill"
  bodyClass="theme-gold-spine"
>

  <!-- (a) INTRO -->
  <section class="section" data-hero>
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="In memoriam" />
      <h1 data-reveal>Pater Frido Pflüger SJ</h1>
      <p class="frido__dates" data-reveal>1947–2021</p>
      <p class="lead" style="margin-top:var(--sp-6)" data-reveal>
        Jesuit, Lehrer, schließlich Landesdirektor des Jesuit Refugee Service in Uganda:
        Über fünfzehn Jahre seines Lebens galten der Bildung von Mädchen in Adjumani in
        Norduganda. Im Juni 2021 starb er in Kampala.
      </p>
      <p class="prose" style="margin-top:var(--sp-5);color:var(--stone)" data-reveal>
        Dieser Verein trägt seinen Namen — nicht als Nachruf, sondern als Versprechen.
        Sieben Abiturienten des Kollegs St. Blasien, die ihn als Lehrer erlebt haben,
        führen weiter, was er in Adjumani begonnen hat: Schulplätze für Mädchen, denen
        Bildung den Weg in ein eigenes Leben öffnet.
      </p>
    </div>
  </section>

  <!-- (b) PULL-QUOTE -->
  <section class="section--tight">
    <div class="container container-text" data-reveal-group>
      <blockquote class="pullquote" data-reveal>
        „Begleitung, nicht nur Hilfe.&ldquo;
      </blockquote>
      <p class="frido__quote-source" data-reveal>
        Bildung als Dienst an der Würde des Menschen — das war Fridos Ethos.
      </p>
    </div>
  </section>

  <!-- (c) THE TIMELINE -->
  <section class="section">
    <div class="container container-text">
      <div class="section-head" data-reveal>
        <Eyebrow text="Ein Leben im Dienst" />
        <h2>Von Albbruck nach Adjumani.</h2>
      </div>

      <ol class="timeline" data-spine-page="frido">
        {timeline.map((t) => (
          <li class="timeline__item" data-reveal>
            <span class="timeline__node" aria-hidden="true"></span>
            <span class="timeline__rail" aria-hidden="true"></span>
            <span class="timeline__year">{t.year}</span>
            <h3>{t.heading}</h3>
            <p style="color:var(--stone);margin-top:var(--sp-2)">{t.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- (d) CONTINUITY BRIDGE — dark band -->
  <section class="band band-dark section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="Die Linie reißt nicht ab" />
      <h2 data-reveal>Was er begann, geht weiter.</h2>
      <p class="lead" style="margin-top:var(--sp-5)" data-reveal>
        Sieben Abiturienten des Kollegs St. Blasien führen Fridos Werk fort. Es sind
        dieselben Schulen, dieselben Mädchen, derselbe Partner: der Jesuit Refugee Service.
      </p>
      <p style="margin-top:var(--sp-5)" data-reveal>
        Was Frido in Adjumani aufgebaut hat, lebt heute in jedem Schuljahr weiter, das wir
        finanzieren — Stand Schuljahr 2024/25 für 24 Kinder, davon 18 Mädchen, von denen
        100 % in der Schule bleiben. Die Begleitung, die er meinte, ist nicht zu Ende; sie
        hat nur die Hände gewechselt.
      </p>
      <p style="margin-top:var(--sp-6)" data-reveal>
        <a class="link-tertiary" href="/projekt">Sehen, wie aus 900 € ein Schuljahr wird →</a>
      </p>
    </div>
  </section>

  <!-- (e) CTA -->
  <CTABand
    eyebrow="In seinem Namen handeln"
    heading="Begleitung, nicht nur Hilfe."
    text="Ein Schuljahr kostet 900 €. Ihre Mitgliedschaft macht Fridos Versprechen zur verlässlichen Zukunft eines Mädchens."
    primaryHref="/mitmachen"
    primaryLabel="Mitglied werden"
    secondaryHref="https://www.betterplace.org/de/projects/165916-schulstipendien-fuer-maedchen-in-uganda-bildung-ist-ihre-zukunft"
    secondaryLabel="Jetzt spenden"
  />

</Layout>

<style>
  /* Page-local layout only — uses existing tokens, no new globals. */
  .frido__dates {
    font-family: var(--font-serif);
    font-size: var(--step-2);
    color: var(--gold);
    margin-top: var(--sp-3);
    letter-spacing: 0.02em;
  }
  .frido__quote-source {
    margin-top: var(--sp-4);
    color: var(--stone);
    font-size: var(--step-0);
  }
</style>
