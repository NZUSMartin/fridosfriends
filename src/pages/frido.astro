---
import Layout from '../layouts/Layout.astro';

const timeline = [
  { year: '1947', event: 'Geburt in Albbruck, Baden-Württemberg' },
  { year: '1966', event: 'Eintritt in die Gesellschaft Jesu (Jesuiten)' },
  { year: '2003', event: 'Beginn des Einsatzes in Adjumani, Uganda' },
  { year: '2006', event: 'Aufbau von Bildungsprogrammen für Flüchtlingskinder mit JRS' },
  { year: '2018', event: 'Country Director JRS Uganda' },
  { year: '19./20. Juni 2021', event: 'Tod in Kampala, Uganda. Sein Werk lebt weiter.' },
];
---
<Layout title="Pater Frido Pflueger SJ" lang="de" currentPath="/frido">

  <section style="padding:4rem 1.5rem 2rem;max-width:860px;margin:0 auto;">
    <p style="color:var(--gold);font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.5rem;">In Memoriam</p>
    <h1 style="font-family:'Source Serif 4',Georgia,serif;font-size:clamp(2rem,4vw,2.8rem);font-weight:700;color:var(--ink);margin:0 0 1.5rem;">Pater Frido Pflueger SJ</h1>
    <p style="color:var(--stone);font-size:1.1rem;line-height:1.8;margin-bottom:1rem;">
      Frido Pflueger war Jesuit, Seelsorger und Menschenrechtsaktivist. Zwanzig Jahre lang setzte er sich in Adjumani dafür ein, dass Flüchtlingskinder — besonders Mädchen — Zugang zu Bildung bekommen. Er starb im Juni 2021 in Kampala.
    </p>
  </section>

  <section style="padding:3rem 1.5rem 4rem;background:var(--paper-pure);">
    <div style="max-width:680px;margin:0 auto;">
      <h2 style="font-family:'Source Serif 4',Georgia,serif;font-size:1.6rem;font-weight:700;color:var(--ink);margin:0 0 2.5rem;">Sein Weg</h2>
      <div style="position:relative;padding-left:2rem;">
        <div style="position:absolute;left:0;top:12px;bottom:12px;width:3px;background:linear-gradient(to bottom, var(--gold), var(--teal));border-radius:2px;"></div>
        {timeline.map(item => (
          <div style="position:relative;margin-bottom:2rem;padding-left:1.5rem;">
            <div style="position:absolute;left:-2.35rem;top:4px;width:14px;height:14px;border-radius:50%;background:var(--gold);border:3px solid var(--paper-pure);"></div>
            <p style="color:var(--gold);font-size:0.8rem;font-weight:700;letter-spacing:0.08em;margin:0 0 0.25rem;">{item.year}</p>
            <p style="color:var(--ink);line-height:1.6;margin:0;">{item.event}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="background:var(--ink);color:#fff;padding:4rem 1.5rem;text-align:center;">
    <blockquote style="max-width:640px;margin:0 auto;font-family:'Source Serif 4',Georgia,serif;font-size:1.5rem;font-style:italic;line-height:1.6;color:#e8e4dc;">
      „Bildung ist keine Wohltat. Sie ist ein Recht — und eine Pflicht für uns alle, es zu schützen."
    </blockquote>
    <p style="margin-top:1.5rem;color:var(--gold-soft);font-size:0.9rem;">— Pater Frido Pflueger SJ</p>
  </section>

  <section style="padding:4rem 1.5rem;max-width:860px;margin:0 auto;text-align:center;">
    <a href="/mitmachen" style="background:var(--teal);color:#fff;padding:14px 28px;border-radius:8px;font-weight:700;text-decoration:none;font-size:1rem;">In seinem Namen spenden</a>
  </section>

</Layout>
