---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Startseite" lang="de" currentPath="/">

  <!-- Hero -->
  <section style="position:relative;min-height:520px;display:flex;align-items:flex-end;overflow:hidden;">
    <img src="/images/students-path.jpg" alt="Drei Schülerinnen auf dem Weg zur Schule in Adjumani, Uganda"
         style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;" />
    <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(28,27,25,0.78) 0%, rgba(28,27,25,0.2) 60%, transparent 100%);"></div>
    <div style="position:relative;z-index:1;max-width:720px;margin:0 auto;padding:3rem 1.5rem;width:100%;">
      <p style="color:var(--gold);font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:1rem;">Frido's Friends e.V.</p>
      <h1 style="font-family:'Source Serif 4',Georgia,serif;color:#fff;font-size:clamp(2rem,5vw,3.2rem);font-weight:700;line-height:1.2;margin:0 0 1.2rem;">
        Bildung ist die einzige Investition,<br>die niemand mehr wegnehmen kann.
      </h1>
      <p style="color:#e8e4dc;font-size:1.1rem;line-height:1.6;margin-bottom:2rem;max-width:560px;">
        Wir finanzieren Stipendien für Mädchen im Flüchtlingslager Adjumani, Uganda — damit Bildung keine Frage des Schicksals ist.
      </p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;">
        <a href="/mitmachen" style="background:var(--teal);color:#fff;padding:14px 28px;border-radius:8px;font-weight:700;font-size:1rem;text-decoration:none;">Jetzt spenden</a>
        <a href="/projekt" style="background:transparent;color:#fff;padding:14px 28px;border-radius:8px;font-weight:600;font-size:1rem;text-decoration:none;border:2px solid rgba(255,255,255,0.6);">Mehr erfahren</a>
      </div>
    </div>
    <figcaption style="position:absolute;bottom:8px;right:12px;color:rgba(255,255,255,0.6);font-size:0.72rem;">by JRS Uganda</figcaption>
  </section>

  <!-- Promise Band -->
  <section style="background:var(--teal);color:#fff;padding:1.25rem 1.5rem;text-align:center;">
    <p style="margin:0;font-size:1.05rem;font-weight:600;letter-spacing:0.02em;">
      100 % Ihrer Spende fließt direkt in Stipendien — kein Euro für Verwaltung.
    </p>
  </section>

  <!-- Stats -->
  <section style="background:var(--paper-pure);padding:4rem 1.5rem;">
    <div class="max-w-5xl mx-auto">
      <p style="text-align:center;color:var(--stone);font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:3rem;">Schuljahr 2024/25</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:2rem;text-align:center;">
        {[
          { value: '24', label: 'Kinder insgesamt' },
          { value: '18', label: 'Mädchen mit Stipendium' },
          { value: '100 %', label: 'Schulverbleib' },
          { value: '€ 900', label: 'pro Stipendium / Jahr' },
        ].map(s => (
          <div>
            <p style="font-family:'Source Serif 4',Georgia,serif;font-size:3rem;font-weight:700;color:var(--gold);margin:0 0 0.5rem;">{s.value}</p>
            <p style="color:var(--stone);font-size:0.9rem;margin:0;">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section style="padding:4rem 1.5rem;background:var(--paper);">
    <div class="max-w-5xl mx-auto">
      <p style="color:var(--gold);font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.5rem;text-align:center;">So funktioniert es</p>
      <h2 style="font-family:'Source Serif 4',Georgia,serif;font-size:2rem;font-weight:700;text-align:center;margin:0 0 3rem;color:var(--ink);">Ihr Geld wirkt direkt</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:2rem;">
        {[
          { step: '1', title: 'Sie spenden', text: 'Per Überweisung oder Dauerauftrag. Kein Zwischenhändler, keine Plattformgebühr.' },
          { step: '2', title: 'JRS Uganda wählt aus', text: 'Der Jesuit Refugee Service identifiziert Mädchen, die sonst keine Chance hätten.' },
          { step: '3', title: 'Stipendium wirkt', text: 'Schulgebühren, Internat, Bücher und Uniform — ein ganzes Schuljahr gesichert.' },
        ].map(item => (
          <div style="background:var(--paper-pure);border-radius:12px;padding:2rem;border:1px solid var(--line);">
            <div style="width:44px;height:44px;border-radius:50%;background:var(--gold);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.1rem;margin-bottom:1rem;">{item.step}</div>
            <h3 style="font-family:'Source Serif 4',Georgia,serif;font-size:1.2rem;font-weight:700;margin:0 0 0.75rem;color:var(--ink);">{item.title}</h3>
            <p style="color:var(--stone);line-height:1.6;margin:0;font-size:0.95rem;">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Photo break -->
  <figure style="margin:0;position:relative;">
    <img src="/images/classroom-students.jpg" alt="Schülerinnen und Schüler im Unterricht in Adjumani"
         style="width:100%;height:380px;object-fit:cover;object-position:center top;display:block;" />
    <figcaption style="text-align:right;padding:0.5rem 1rem;background:var(--ink);color:rgba(255,255,255,0.5);font-size:0.75rem;">by JRS Uganda</figcaption>
  </figure>

  <!-- Grace story teaser -->
  <section style="padding:4rem 1.5rem;background:var(--paper-pure);">
    <div class="max-w-5xl mx-auto">
      <p style="color:var(--gold);font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:2rem;">Eine Geschichte</p>
      <div style="display:grid;grid-template-columns:280px 1fr;gap:2.5rem;align-items:start;" class="story-grid">
        <figure style="margin:0;">
          <img src="/images/student-classroom-portrait.jpg" alt="Grace, Stipendiatin aus Adjumani"
               style="width:100%;border-radius:10px;display:block;aspect-ratio:3/4;object-fit:cover;" />
          <figcaption style="color:var(--stone);font-size:0.75rem;margin-top:0.5rem;text-align:center;">by JRS Uganda</figcaption>
        </figure>
        <div class="grid-child-min">
          <h2 style="font-family:'Source Serif 4',Georgia,serif;font-size:2rem;font-weight:700;color:var(--ink);margin:0 0 1rem;">Grace will Ärztin werden.</h2>
          <p style="color:var(--stone);line-height:1.8;font-size:1.05rem;margin-bottom:1.5rem;">
            Grace ist 16 Jahre alt und lebt seit ihrem fünften Lebensjahr im Flüchtlingslager Adjumani. Ohne Stipendium wäre die Schule nach der Grundschule vorbei gewesen. Heute träumt sie davon, ihrer Gemeinschaft als Ärztin zu helfen.
          </p>
          <a href="/geschichten" style="color:var(--teal);font-weight:700;text-decoration:none;font-size:1rem;">
            Graces Geschichte lesen →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Dark CTA band -->
  <section style="background:var(--ink);color:#fff;padding:4rem 1.5rem;text-align:center;">
    <h2 style="font-family:'Source Serif 4',Georgia,serif;font-size:2.2rem;font-weight:700;margin:0 0 1rem;">Werden Sie Teil der Lösung.</h2>
    <p style="color:#b0aba0;font-size:1.05rem;margin:0 0 2rem;max-width:480px;margin-left:auto;margin-right:auto;">
      € 75 im Monat finanziert ein vollständiges Stipendium für ein Jahr.
    </p>
    <a href="/mitmachen" style="background:var(--teal);color:#fff;padding:16px 36px;border-radius:8px;font-weight:700;font-size:1.1rem;text-decoration:none;display:inline-block;">Jetzt spenden</a>
  </section>

  <style>
    @media (max-width: 640px) {
      .story-grid { grid-template-columns: 1fr !important; }
    }
  </style>
</Layout>
