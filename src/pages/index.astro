---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Stat from '../components/Stat.astro';
import Story from '../components/Story.astro';
import PhotoBreak from '../components/PhotoBreak.astro';
import PromiseBand from '../components/PromiseBand.astro';
import CTABand from '../components/CTABand.astro';
import MembershipCalculator from '../components/MembershipCalculator.astro';

const betterplace = 'https://www.betterplace.org/de/projects/165916-schulstipendien-fuer-maedchen-in-uganda-bildung-ist-ihre-zukunft';

const steps = [
  {
    n: '1',
    title: 'JRS wählt aus',
    body: 'Unser Partner vor Ort, der Jesuit Refugee Service, kennt die Familien im Bezirk Adjumani und wählt die Mädchen aus, für die ein Schulplatz alles verändert.',
  },
  {
    n: '2',
    title: 'Wir finanzieren — zu 100 %',
    body: '800 € tragen ein ganzes Schuljahr: Schulgebühren, Material, Hygieneartikel, das Wohnheim und die Begleitung vor Ort. Jeder gespendete Euro fließt in Stipendien.',
  },
  {
    n: '3',
    title: 'Die Mädchen bleiben in der Schule',
    body: 'Stand Schuljahr 2024/25 bleiben 100 % der geförderten Kinder in der Schule. Bildung, die niemand mehr wegnehmen kann.',
  },
];

const multiplier = [
  {
    num: '3–6',
    title: 'Kinder pro Frau',
    body: 'Jede ausgebildete Frau beeinflusst direkt drei bis sechs Kinder — durch das, was sie weitergibt, verdient und vorlebt.',
  },
  {
    num: '~40',
    title: 'Schülerinnen pro Klasse',
    body: 'Wird eine Stipendiatin Lehrerin, erreicht sie pro Klasse rund 40 Kinder Jahr für Jahr (illustrative Projektion).',
  },
  {
    num: '150–300',
    title: 'Geburten pro Jahr',
    body: 'Wird sie Hebamme, begleitet sie 150 bis 300 Geburten im Jahr — sicher, in einer Region, in der das Leben rettet (illustrative Projektion).',
  },
];
---

<Layout title="Bildung ist ihre Zukunft" lang="de" path="/" spine="progress">

  <!-- 1. HERO -->
  <section class="hero section" data-hero>
    <div class="container">
      <div class="hero__grid">
        <div data-reveal-group>
          <Eyebrow text="Bildung ist ihre Zukunft" />
          <h1 data-reveal>Bildung ist die einzige Investition, die niemand mehr wegnehmen kann.</h1>
          <p class="lead" style="margin-top:var(--sp-5)" data-reveal>
            Wir finanzieren Schulstipendien für Mädchen im Flüchtlingsbezirk Adjumani in
            Norduganda — gemeinsam mit dem Jesuit Refugee Service und im Sinne von Pater Frido
            Pflüger. Wenn Sie ein Mädchen fördern, fördern Sie eine ganze Gemeinschaft.
          </p>
          <p class="hero__cost" data-reveal><b>800 €</b> = ein ganzes Schuljahr für ein Mädchen.</p>
          <div class="btn-row" data-reveal>
            <a class="btn btn--primary" href="/mitmachen">Mitmachen</a>
            <a class="btn btn--secondary" href="#so-funktioniert-es">Mehr erfahren</a>
          </div>
        </div>

        <figure class="figure hero__media" data-reveal>
          <img
            src="/images/start-adjumani.jpg"
            alt="Zwei Schülerinnen vor ihrer Schule in Adjumani, Norduganda"
            width="1600" height="1067"
            style="object-fit:cover"
            fetchpriority="high" loading="eager" decoding="async"
          />
          <figcaption>Foto: JRS Uganda</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- 2. 100 % PROMISE BAND (LOUD, dark) -->
  <PromiseBand lang="de" />

  <!-- 3. WIRKUNG / STATS — auf einen Blick -->
  <section class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Wirkung" />
        <h2>Kleine Zahlen, die alles verändern.</h2>
      </div>
      <div class="stats" data-reveal-group>
        <Stat figure="24"   countTo={24}  label="Kinder gefördert" />
        <Stat figure="18"   countTo={18}  label="davon Mädchen" />
        <Stat figure="100%" countTo={100} suffix="%" label="bleiben in der Schule" />
        <Stat figure="800 €" label="finanzieren ein Schuljahr" />
      </div>
      <p class="caption" style="margin-top:var(--sp-5)" data-reveal>Stand: Schuljahr 2024/25</p>
    </div>
  </section>

  <!-- 4. EINE GESCHICHTE — JO -->
  <section class="section">
    <div class="container">
      <Story
        image="/images/student-classroom-portrait.jpg"
        alt="Jo sitzt aufrecht und selbstbewusst vor einer Tafel"
        eyebrow="Eine von 24"
        heading="Jo wäre mit 15 verheiratet gewesen."
        quote="Ich will Hebamme werden, damit Mütter in meiner Siedlung sicher zur Welt bringen können."
        linkHref="/geschichten"
        linkLabel="Mehr Geschichten →"
      >
        <p>
          Mit etwa 15 Jahren stand Jo kurz vor der Heirat. Ein Stipendium ließ sie in der
          Schule bleiben — und veränderte ihren Weg. Heute ist sie Klassensprecherin.
        </p>
        <p>
          Sie möchte Hebamme werden: nicht irgendwo, sondern in ihrer eigenen Siedlung, damit
          Mütter dort sicher gebären können. Ein Schulplatz, der zu einem ganzen Berufsleben wird.
        </p>
      </Story>
    </div>
  </section>

  <!-- 5. PHOTO BREAK — MULTIPLIKATOR -->
  <PhotoBreak
    src="/images/classroom-students.jpg"
    alt="Ein voll besetztes Klassenzimmer mit aufmerksamen Schülerinnen und Schülern"
    eyebrow="Der Multiplikator"
    heading="Wer ein Mädchen ausbildet, verändert eine Gemeinschaft."
  />

  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="lead">
          Mädchenbildung hat in Flüchtlingsregionen den höchsten langfristigen Multiplikator.
          Aus Stipendiatinnen werden Krankenschwestern, Hebammen, Lehrerinnen und Beamtinnen —
          und jede von ihnen gibt das Gelernte weiter.
        </p>
      </div>
      <div class="grid-3" data-reveal-group>
        {multiplier.map((m) => (
          <article class="card card--story" data-reveal>
            <span class="card__num">{m.num}</span>
            <h3>{m.title}</h3>
            <p style="color:var(--stone);margin-top:var(--sp-3)">{m.body}</p>
          </article>
        ))}
      </div>
      <p class="caption" style="margin-top:var(--sp-5)" data-reveal>
        Zahlen als illustrative Projektion. Im Raum Adjumani hat JRS-nahe Mädchenbildung über
        die Jahre rund 30.000 Mädchen erreicht.
      </p>
    </div>
  </section>

  <!-- 6. WORAN WIR GLAUBEN -->
  <section class="section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="Woran wir glauben" />
      <h2 data-reveal>Woran wir glauben</h2>
      <p class="prose" style="margin-top:var(--sp-5)" data-reveal>
        Eine gute Schulbildung wird immer mehr zum Privileg — wir wollen dagegenhalten und dazu
        beitragen, dass möglichst viele Kinder davon profitieren. Unser Erziehungsideal basiert
        auf Respekt, Chancengleichheit und der Förderung jedes einzelnen Kindes. Wir sind
        überzeugt, dass Bildung weit mehr ist als Wissensvermittlung: Sie stärkt
        Selbstvertrauen, Verantwortungsbewusstsein und die Fähigkeit, die eigene Zukunft aktiv
        zu gestalten. Dabei stehen die Würde, die individuellen Talente und die ganzheitliche
        Entwicklung der Kinder stets im Mittelpunkt unseres Handelns.
      </p>
    </div>
  </section>

  <!-- 7. SO FUNKTIONIERT ES -->
  <section id="so-funktioniert-es" class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="So funktioniert es" />
        <h2>Vom Beitrag zum Schulplatz — in drei klaren Schritten.</h2>
      </div>
      <div class="grid-3" data-reveal-group>
        {steps.map((s) => (
          <article class="card" data-reveal>
            <span class="card__num">{s.n}</span>
            <h3>{s.title}</h3>
            <p style="color:var(--stone);margin-top:var(--sp-3)">{s.body}</p>
          </article>
        ))}
      </div>
      <p style="margin-top:var(--sp-6)" data-reveal>
        <a class="link-tertiary" href="/projekt">Den vollständigen Mittelfluss und die 800-€-Aufteilung ansehen →</a>
      </p>
    </div>
  </section>

  <!-- 8. MITMACHEN — CALCULATOR -->
  <section class="section">
    <div class="container">
      <div class="story">
        <div data-reveal>
          <Eyebrow text="Mitmachen" />
          <h2>Werden Sie Teil von Frido&rsquo;s Friends.</h2>
          <p class="prose" style="margin-top:var(--sp-4);color:var(--stone)">
            Eine regelmäßige Mitgliedschaft gibt einem Mädchen Planungssicherheit über das
            ganze Schuljahr. Schon 75 € im Monat tragen ein komplettes Schuljahr — Schulgebühren,
            Material, Hygieneartikel, das Wohnheim für diejenigen mit weitem Schulweg und die
            Begleitung vor Ort.
          </p>
          <p class="prose" style="margin-top:var(--sp-4);color:var(--stone)">
            Lieber einmalig spenden? Auch das geht — über betterplace.org, inklusive
            Spendenquittung.
          </p>
        </div>
        <div data-reveal>
          <MembershipCalculator lang="de" />
        </div>
      </div>
    </div>
  </section>

  <!-- 9. FRIDO-TEASER (dark) -->
  <section class="band band-dark section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="Warum wir das tun" />
      <p class="lead" data-reveal>
        „Begleitung, nicht nur Hilfe.&ldquo; — Pater Frido Pflüger SJ hat in Adjumani Bildung
        als Dienst an der Würde des Menschen verstanden. Sieben Freunde aus dem Kolleg
        St. Blasien setzen sein Werk fort.
      </p>
      <p style="margin-top:var(--sp-5)" data-reveal>
        <a class="link-tertiary" href="/frido">Pater Frido kennenlernen →</a>
      </p>
    </div>
  </section>

  <!-- 10. DARK CTA BAND -->
  <CTABand
    heading="Begleitung, nicht nur Hilfe."
    text="Ein Schuljahr kostet 800 €. Ihre Mitgliedschaft macht es zur verlässlichen Zukunft eines Mädchens."
    primaryHref="/mitmachen"
    primaryLabel="Mitmachen"
    secondaryHref={betterplace}
    secondaryLabel="Jetzt spenden"
  />

</Layout>
