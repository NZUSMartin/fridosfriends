---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import PhotoBreak from '../components/PhotoBreak.astro';
import CTABand from '../components/CTABand.astro';

const betterplace = 'https://www.betterplace.org/de/projects/165916-schulstipendien-fuer-maedchen-in-uganda-bildung-ist-ihre-zukunft';

// (c) Was 800 € leisten — itemized breakdown of one scholarship
const coverage = [
  {
    title: '100 % der Schulgebühren',
    body: 'Der vollständige Schulplatz an einer weiterführenden Schule. Der JRS achtet auch auf unseren Wunsch hin darauf, dass Eltern, wenn möglich, einen Eigenanteil beisteuern. Das stärkt die Verantwortung vor Ort.',
  },
  {
    title: 'Schulmaterialien',
    body: 'Hefte, Stifte, Bücher und Uniform — alles, was ein Mädchen braucht, um vom ersten Tag an mitzuhalten.',
  },
  {
    title: 'Hygieneartikel inkl. Menstruationsprodukte',
    body: 'Damit kein Mädchen aus Mangel an Produkten Schultage verpasst.',
  },
  {
    title: 'Internat — für Mädchen, deren Schulweg zu weit ist',
    body: 'Nicht alle Stipendiatinnen wohnen im Internat; nur die, deren Schulweg zu weit ist, leben unter der Woche im Wohnheim. So bleibt der Schulbesuch verlässlich möglich.',
  },
  {
    title: 'Mentoring durch lokale Begleiter',
    body: 'Begleitung statt bloßer Hilfe: Menschen vor Ort, die jedes Mädchen über das Schuljahr hinweg stärken. Es ist die Perspektive, die Bildung eröffnet, die die Dynamik früher Verheiratung verändert.',
  },
];

// (d) 4-step Mittelfluss chain
const flow = [
  {
    n: '1',
    title: 'Ihre Spende',
    body: 'Als Mitglied oder mit einer einmaligen Spende geben Sie den ersten Anstoß.',
  },
  {
    n: '2',
    title: 'Frido’s Friends bündelt und überweist',
    body: 'Wir bündeln die Beiträge und überweisen sie quartalsweise an den Jesuit Refugee Service (JRS).',
  },
  {
    n: '3',
    title: 'JRS führt Zahlungen und Sachleistungen durch und überwacht die Ausgaben',
    body: 'Unser Partner vor Ort führt Zahlungen und Sachleistungen durch und überwacht, wie die Mittel verwendet werden — kein Umweg, keine Verwaltungskosten in Deutschland.',
  },
  {
    n: '4',
    title: 'Das Mädchen bleibt in der Schule',
    body: 'Aus einem Beitrag wird ein Schulplatz: Stand Schuljahr 2024/25 bleiben 100 % der geförderten Kinder in der Schule.',
  },
];

// (f) JRS in Zahlen
const jrsFacts = [
  { figure: '~30.000', label: 'Mädchen über die Jahre durch JRS-nahe Bildung im Raum Adjumani erreicht (Quelle: JRS)' },
  { figure: 'Seit 2003', label: 'baute Pater Frido mit JRS in Adjumani Bildungsprogramme auf' },
  { figure: '100 %', label: 'der geförderten Kinder bleiben in der Schule (Stand: Schuljahr 2024/25)' },
];
---

<Layout title="Das Projekt" lang="de" path="/projekt" spine="fill">

  <!-- (a) INTRO -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal-group>
        <Eyebrow text="Das Projekt" />
        <h1 data-reveal>Adjumani in Norduganda — wo ein Schulplatz alles entscheidet.</h1>
        <p class="lead" style="margin-top:var(--sp-5)" data-reveal>
          Rund zwei Millionen Geflüchtete leben in Uganda — viele von ihnen im Bezirk Adjumani
          im Norden des Landes. Mädchen sind hier besonders ausgeschlossen: Frühheirat mit 14
          bis 16 Jahren ist verbreitet, ein Schulzugang oft nicht selbstverständlich. Bildung
          ist der einzige nachhaltige Weg aus diesem Kreislauf — und genau dort setzen wir an.
        </p>
      </div>
    </div>
  </section>

  <!-- (b) CONTEXT PHOTO -->
  <PhotoBreak
    src="/images/student-corridor-flowers.jpg"
    alt="Eine Schülerin steht in einem sonnendurchfluteten Schulkorridor in Adjumani"
    eyebrow="Adjumani, Norduganda"
    heading="Für ein Mädchen beginnt Zukunft mit einem sicheren Schulweg."
  />

  <!-- (c) WAS 800 € LEISTEN -->
  <section class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Was 800 € leisten" />
        <h2>Ein Stipendium trägt ein ganzes Schuljahr — vollständig.</h2>
      </div>

      <div class="coverage" data-reveal-group>
        <dl class="coverage__list">
          {coverage.map((item) => (
            <div class="coverage__item" data-reveal>
              <dt>{item.title}</dt>
              <dd>{item.body}</dd>
            </div>
          ))}
        </dl>

        <aside class="coverage__total card card--story" data-reveal>
          <Eyebrow text="Ein Schuljahr" />
          <p class="coverage__figure">800&nbsp;€</p>
          <p class="coverage__per">pro Jahr und Mädchen</p>
          <p class="coverage__note">
            Alles oben Genannte ist darin enthalten. 100 % Ihrer Spende fließen direkt in
            Stipendien — keine Verwaltungskosten in Deutschland.
          </p>
        </aside>
      </div>
    </div>
  </section>

  <!-- (d) MITTELFLUSS — 4 steps -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Der Mittelfluss" />
        <h2>Von Ihrer Spende bis zum Schulplatz — vier klare Schritte.</h2>
      </div>

      <ol class="flow-chain" data-reveal-group>
        {flow.map((step) => (
          <li class="flow-chain__item" data-reveal>
            <span class="flow-chain__node" aria-hidden="true"></span>
            <span class="flow-chain__num">{step.n}</span>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- (e) PHOTO BREAK -->
  <PhotoBreak
    src="/images/girls-group-smiling.jpg"
    alt="Eine Gruppe von sieben Schülerinnen in rot-weißen Uniformen steht selbstbewusst zusammen"
    eyebrow="Gemeinsam stärker"
    heading="Jedes geförderte Mädchen verändert mehr als ein einzelnes Leben."
  />

  <!-- (f) JRS PARTNERSHIP -->
  <section id="jrs" class="band band-pure section">
    <div class="container">
      <div class="story">
        <div data-reveal>
          <Eyebrow text="Unser Partner" />
          <h2>Der Jesuit Refugee Service — seit Jahrzehnten in Adjumani verwurzelt.</h2>
          <div class="prose" style="margin-top:var(--sp-5)">
            <p>
              Der Jesuit Refugee Service (JRS) ist seit vielen Jahren fest im Bezirk Adjumani
              verankert. Er kennt die Familien, die Schulen und die Lehrkräfte — und wählt
              gemeinsam mit ihnen die Mädchen aus, für die ein Schulplatz alles verändert.
            </p>
            <p>
              Der jesuitische Flüchtlingsdienst in Uganda ist unser Partner bei der Umsetzung und
              verwaltet die von Frido&rsquo;s Friends finanzierten Stipendien als Teil seines
              Landesprogramms. <a class="link-tertiary" href="https://ear.jrs.net/en/country/uganda/" target="_blank" rel="noopener">JRS Uganda kennenlernen&nbsp;→</a>
            </p>
            <p>
              JRS arbeitet nach klaren Schutzstandards: Über unsere Stipendiatinnen werden
              öffentlich nur Vorname und Berufswunsch genannt — keine Nachnamen, keine
              Familien- oder Ortsangaben. Würde und Sicherheit der Mädchen stehen an erster
              Stelle.
            </p>
            <p>
              Pater Frido Pflüger SJ hat über viele Jahre mit JRS in Ostafrika gearbeitet —
              ab 2003 in Adjumani, später als Regionaldirektor für Ostafrika und zuletzt als
              Landesdirektor in Uganda. Diese gewachsene Beziehung ist das Fundament unserer Arbeit.
            </p>
          </div>
        </div>

        <aside class="card jrs-card" data-reveal>
          <Eyebrow text="JRS in Zahlen" />
          <dl class="jrs-card__stats">
            {jrsFacts.map((f) => (
              <div class="jrs-card__stat">
                <dt>{f.figure}</dt>
                <dd>{f.label}</dd>
              </div>
            ))}
          </dl>
          <p class="jrs-card__source">Quelle: JRS. Angaben über die Jahre; Schulverbleib Stand Schuljahr&nbsp;2024/25.</p>
          <ul class="trust-row">
            <li>Schwerpunkt Sekundarabschluss</li>
            <li>Begleitung und Perspektive durch Bildung</li>
            <li>Berichtspflicht gegenüber Frido&rsquo;s Friends</li>
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- (g) CTA BAND -->
  <CTABand
    eyebrow="Mitmachen"
    heading="Geben Sie einem Mädchen ein ganzes Schuljahr."
    text="800 € tragen ein Jahr — Schulgebühren, Material, Hygieneartikel, Internat und Begleitung. Ihre Mitgliedschaft macht daraus verlässliche Zukunft."
    primaryHref="/mitmachen"
    primaryLabel="Mitmachen"
    secondaryHref={betterplace}
    secondaryLabel="Jetzt spenden"
  />

</Layout>

<style>
  /* (c) Coverage — definition layout + thin gold-tick accent. Teal NEVER used here. */
  .coverage {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-7);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .coverage { grid-template-columns: 1fr 320px; gap: var(--sp-8); }
  }
  .coverage__list { margin: 0; }
  .coverage__item {
    padding: var(--sp-5) 0;
    border-top: 1px solid var(--line);
  }
  .coverage__item:first-child { border-top: 0; padding-top: 0; }
  .coverage__item dt {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: var(--step-1);
    color: var(--ink);
    line-height: 1.25;
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
  }
  .coverage__item dt::before {
    content: "";
    flex: 0 0 auto;
    width: 18px;
    border-top: 2px solid var(--gold);
    transform: translateY(-4px);
  }
  .coverage__item dd {
    margin: var(--sp-2) 0 0;
    padding-left: calc(18px + var(--sp-3));
    color: var(--stone);
    max-width: 60ch;
  }

  .coverage__total {
    position: sticky;
    top: calc(72px + var(--sp-5));
  }
  .coverage__figure {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: var(--step-5);
    line-height: 1;
    color: var(--gold);
    margin: var(--sp-3) 0 0;
    font-variant-numeric: tabular-nums;
  }
  .coverage__per {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    color: var(--stone);
    margin: var(--sp-2) 0 0;
  }
  .coverage__note {
    margin: var(--sp-5) 0 0;
    color: var(--stone);
    font-size: var(--step--1);
    line-height: 1.6;
  }

  /* (d) Mittelfluss chain — continuity/timeline connector style */
  .flow-chain {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .flow-chain__item {
    position: relative;
    padding-left: var(--sp-7);
    padding-bottom: var(--sp-8);
  }
  .flow-chain__item:last-child { padding-bottom: 0; }
  /* the connector rail between nodes */
  .flow-chain__item::before {
    content: "";
    position: absolute;
    left: 4px;
    top: var(--sp-2);
    bottom: 0;
    width: 1px;
    background: var(--line);
  }
  .flow-chain__item:last-child::before { display: none; }
  .flow-chain__node {
    position: absolute;
    left: 0;
    top: 6px;
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: var(--gold);
    box-shadow: 0 0 0 4px var(--paper);
  }
  .flow-chain__num {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: var(--step-2);
    color: var(--gold);
    display: block;
    line-height: 1;
  }
  .flow-chain__item h3 { margin: var(--sp-2) 0 var(--sp-3); }
  .flow-chain__item p { color: var(--stone); max-width: 60ch; }

  /* (f) JRS card */
  .jrs-card { align-self: start; }
  .jrs-card__stats { margin: var(--sp-4) 0 0; }
  .jrs-card__stat {
    padding: var(--sp-4) 0;
    border-top: 1px solid var(--line);
  }
  .jrs-card__stat:first-child { border-top: 0; padding-top: 0; }
  .jrs-card__stat dt {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: var(--step-2);
    line-height: 1.05;
    color: var(--gold);
  }
  .jrs-card__stat dd {
    margin: var(--sp-2) 0 0;
    color: var(--stone);
    font-size: var(--step--1);
    line-height: 1.5;
  }
  .jrs-card__source {
    margin: var(--sp-4) 0 0;
    color: var(--stone);
    font-size: var(--step--2);
    line-height: 1.5;
  }
</style>
