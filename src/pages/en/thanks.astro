---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/Eyebrow.astro';

const betterplace = 'https://www.betterplace.org/de/projects/165916-schulstipendien-fuer-maedchen-in-uganda-bildung-ist-ihre-zukunft';
---
<Layout
  title="Thank you"
  description="Thank you for your membership application to Frido's Friends e.V. We will be in touch within 24–48 hours."
  lang="en"
  path="/en/thanks"
  spine="none"
>
  <section class="section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="Application received" />
      <h1 data-reveal>Thank you.</h1>
      <p class="lead" style="margin-top:var(--sp-5)" data-reveal>
        Your membership application has reached us. We will get back to you personally within
        24–48 hours — with the membership form and the SEPA mandate for your contribution.
      </p>
      <p style="margin-top:var(--sp-5);color:var(--stone)" data-reveal>
        If you would like to help straight away, you can also donate directly via
        <a class="link-tertiary" href={betterplace} rel="noopener" target="_blank">betterplace.org</a>.
        For any questions, reach us anytime at
        <a class="link-tertiary" href="mailto:vorstand@fridosfriends.de">vorstand@fridosfriends.de</a>.
      </p>
      <p style="margin-top:var(--sp-6)" data-reveal>
        <a class="btn btn--secondary" href="/en/">Back to home</a>
      </p>
    </div>
  </section>
</Layout>
