---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="About us" lang="en" currentPath="/en/about">
  <section style="padding:4rem 1.5rem;max-width:860px;margin:0 auto;">
    <p style="color:var(--gold);font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.5rem;">About us</p>
    <h1 style="font-family:'Source Serif 4',Georgia,serif;font-size:clamp(2rem,4vw,2.8rem);font-weight:700;color:var(--ink);margin:0 0 1.5rem;">Seven people, one idea</h1>
    <p style="color:var(--stone);font-size:1.1rem;line-height:1.8;margin-bottom:2rem;">Frido's Friends e.V. was founded on 15 August 2025 by seven friends who knew Father Frido Pflueger SJ personally. We are registered at Amtsgericht Köln and recognised as a charitable association. All board members serve voluntarily.</p>
    <h2 style="font-family:'Source Serif 4',Georgia,serif;font-size:1.4rem;font-weight:700;color:var(--ink);margin:2rem 0 1rem;">Board</h2>
    <ul style="color:var(--stone);line-height:2;padding:0;list-style:none;">
      <li><strong style="color:var(--ink);">Dominik Bartsch</strong> — Chair</li>
      <li><strong style="color:var(--ink);">Martin Hirt</strong> — Treasurer</li>
      <li><strong style="color:var(--ink);">Lorenz Dietsche</strong> — Board member</li>
    </ul>
  </section>
</Layout>
