---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import PromiseBand from '../../components/PromiseBand.astro';
import CTABand from '../../components/CTABand.astro';

const betterplace = 'https://www.betterplace.org/de/projects/165916-schulstipendien-fuer-maedchen-in-uganda-bildung-ist-ihre-zukunft';

const board = [
  {
    name: 'Dominik Bartsch',
    role: 'Chairman',
    body: 'Leads the association and keeps the relationship with the Jesuit Refugee Service in Uganda. He makes sure that every decision serves our statutory purpose: the schooling of girls in Adjumani.',
    email: null,
  },
  {
    name: 'Martin Hirt',
    role: 'Deputy Chairman',
    body: 'Deputises for the chairman and supports the strategic work of the board. He brings in the perspective of the founding members and helps keep the association transparent and run entirely by volunteers.',
    email: null,
  },
  {
    name: 'Lorenz Dietsche',
    role: 'Treasurer',
    body: 'Looks after finances, membership contributions and donation receipts. He guards the 100% promise — that every euro donated flows into scholarships and that administration stays privately funded.',
    email: null,
  },
];

const facts = [
  { dt: 'Founded', dd: '15 August 2025' },
  { dt: 'Registered office', dd: 'Cologne' },
  { dt: 'Court of registration', dd: 'Amtsgericht Köln' },
  { dt: 'Status', dd: 'Recognised charitable association (gemeinnützig)' },
  { dt: 'Statutory purpose', dd: 'Promoting the schooling of children and young people in need in developing countries, in particular Uganda' },
];
---

<Layout title="About us" lang="en" path="/en/about" spine="progress">

  <!-- (a) INTRO -->
  <section class="section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="About us" />
      <h1 data-reveal>Seven friends. One responsibility.</h1>
      <p class="lead" style="margin-top:var(--sp-5)" data-reveal>
        Frido&rsquo;s Friends e.V. was founded on 15 August 2025 by seven friends from Kolleg
        St. Blasien — the class of 1985. What connects us is not only our shared
        school years, but a personal bond with Father Frido Pflüger SJ and with everything he
        lived for: education as a service to human dignity.
      </p>
      <p class="prose" style="margin-top:var(--sp-5);color:var(--stone)" data-reveal>
        We have deliberately stayed small — no large NGO structure, but a lean, transparent
        and efficient association. Who we are is easy to grasp; what we want to achieve is not.
        It is precisely this clarity that lets us make a promise larger organisations can
        rarely give.
      </p>
    </div>
  </section>

  <!-- (b) 100 % PROMISE BAND -->
  <PromiseBand lang="en" />

  <!-- (c) BOARD -->
  <section class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="The board" />
        <h2>Three people, one volunteer mandate.</h2>
      </div>
      <div class="grid-3" data-reveal-group>
        {board.map((member) => (
          <article class="card" data-reveal>
            <h3>{member.name}</h3>
            <Eyebrow text={member.role} as="p" class="board__role" />
            <p style="color:var(--stone);margin-top:var(--sp-3)">{member.body}</p>
            {member.email && (
              <p style="margin-top:var(--sp-4)">
                <a class="link-tertiary" href={`mailto:${member.email}`}>{member.email}</a>
              </p>
            )}
          </article>
        ))}
      </div>

      <div class="card founders-more" data-reveal>
        <Eyebrow text="Other founding members" />
        <ul class="founders-list">
          <li>Iara Behs</li>
          <li>Hartmut Müller-Gerbes</li>
          <li>Robert Schnekenbühl</li>
          <li>Dorothee Thum</li>
        </ul>
      </div>

      <p class="caption" style="margin-top:var(--sp-6);max-width:none" data-reveal>
        Seven friends, five of them from the 1985 graduating class of Kolleg St. Blasien. The board works on a voluntary basis; administrative costs are covered privately.
      </p>
    </div>
  </section>

  <!-- (d) TRANSPARENCY + LEGAL -->
  <section class="section">
    <div class="container container-text" data-reveal-group>
      <div class="section-head" data-reveal>
        <Eyebrow text="Transparency & legal" />
        <h2>What we promise, you can verify.</h2>
      </div>

      <p class="prose" style="color:var(--stone)" data-reveal>
        Once a year we publish an accountability report — open, comprehensible and without
        gloss. Our statutory purpose is the promotion of schooling for children and young
        people in need in developing countries, in particular in Uganda. By that, we ask to
        be measured.
      </p>

      <dl class="facts" data-reveal>
        {facts.map((f) => (
          <div class="facts__row">
            <dt>{f.dt}</dt>
            <dd>{f.dd}</dd>
          </div>
        ))}
      </dl>

      <p class="prose" style="color:var(--stone);margin-top:var(--sp-6)" data-reveal>
        Our work on the ground does not happen alone. We carry forward Father Frido&rsquo;s
        legacy with an experienced partner — the Jesuit Refugee Service, which knows the
        families in the Adjumani district and accompanies the scholarships.
      </p>
      <p style="margin-top:var(--sp-4)" data-reveal>
        <a class="link-tertiary" href="/en/promise">How we keep the 100% promise →</a>
      </p>
      <p style="margin-top:var(--sp-4)" data-reveal>
        <a class="link-tertiary" href="/en/project#jrs">Meet our partner JRS →</a>
      </p>
    </div>
  </section>

  <!-- (e) CTA -->
  <CTABand
    eyebrow="Get involved"
    heading="Become part of this responsibility."
    text="As a member you give a girl the security of a whole school year — €800 covers it in full."
    primaryHref="/en/donate"
    primaryLabel="Get involved"
    secondaryHref={betterplace}
    secondaryLabel="Donate now"
  />

</Layout>

<style>
  /* Page-local layout only — uses existing design tokens (var(--...)). */
  .board__role { margin-top: var(--sp-3); margin-bottom: 0; }

  .facts {
    margin: var(--sp-6) 0 0;
    border-top: 1px solid var(--line);
  }
  .facts__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-1);
    padding: var(--sp-4) 0;
    border-bottom: 1px solid var(--line);
  }
  @media (min-width: 768px) {
    .facts__row {
      grid-template-columns: 220px 1fr;
      gap: var(--sp-5);
      align-items: baseline;
    }
  }
  .facts dt {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--stone);
  }
  .facts dd {
    margin: 0;
    color: var(--ink);
  }
</style>
