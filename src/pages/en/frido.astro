---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Father Frido Pflueger SJ" lang="en" currentPath="/en/frido">
  <section style="padding:4rem 1.5rem;max-width:860px;margin:0 auto;">
    <p style="color:var(--gold);font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.5rem;">In Memoriam</p>
    <h1 style="font-family:'Source Serif 4',Georgia,serif;font-size:clamp(2rem,4vw,2.8rem);font-weight:700;color:var(--ink);margin:0 0 1.5rem;">Father Frido Pflueger SJ</h1>
    <p style="color:var(--stone);font-size:1.1rem;line-height:1.8;margin-bottom:1rem;">Frido Pflueger was a Jesuit priest, pastor, and human rights activist. For twenty years he worked in Adjumani to ensure refugee children — especially girls — had access to education. He died in June 2021 in Kampala.</p>
    <p style="color:var(--stone);font-size:1.1rem;line-height:1.8;">This association bears his name as a commitment: the work he lived for continues.</p>
  </section>
  <section style="background:var(--ink);color:#fff;padding:4rem 1.5rem;text-align:center;">
    <blockquote style="max-width:640px;margin:0 auto;font-family:'Source Serif 4',Georgia,serif;font-size:1.5rem;font-style:italic;line-height:1.6;color:#e8e4dc;">
      "Education is not charity. It is a right — and our duty to protect it."
    </blockquote>
    <p style="margin-top:1.5rem;color:var(--gold-soft);font-size:0.9rem;">— Father Frido Pflueger SJ</p>
  </section>
  <section style="padding:3rem 1.5rem;text-align:center;">
    <a href="/en/donate" style="background:var(--teal);color:#fff;padding:14px 28px;border-radius:8px;font-weight:700;text-decoration:none;font-size:1rem;">Donate in his name</a>
  </section>
</Layout>
