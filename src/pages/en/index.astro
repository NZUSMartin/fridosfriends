---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Home" lang="en" currentPath="/en/">

  <section style="position:relative;min-height:520px;display:flex;align-items:flex-end;overflow:hidden;">
    <img src="/images/students-path.jpg" alt="Three students walking to school in Adjumani, Uganda"
         style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;" />
    <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(28,27,25,0.78) 0%, rgba(28,27,25,0.2) 60%, transparent 100%);"></div>
    <div style="position:relative;z-index:1;max-width:720px;margin:0 auto;padding:3rem 1.5rem;width:100%;">
      <p style="color:var(--gold);font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:1rem;">Frido's Friends e.V.</p>
      <h1 style="font-family:'Source Serif 4',Georgia,serif;color:#fff;font-size:clamp(2rem,5vw,3.2rem);font-weight:700;line-height:1.2;margin:0 0 1.2rem;">
        Education is the only investment<br>no one can ever take away.
      </h1>
      <p style="color:#e8e4dc;font-size:1.1rem;line-height:1.6;margin-bottom:2rem;max-width:560px;">
        We fund scholarships for girls in the Adjumani refugee settlement, Uganda — because education must not be a matter of fate.
      </p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;">
        <a href="/en/donate" style="background:var(--teal);color:#fff;padding:14px 28px;border-radius:8px;font-weight:700;font-size:1rem;text-decoration:none;">Donate now</a>
        <a href="/en/project" style="background:transparent;color:#fff;padding:14px 28px;border-radius:8px;font-weight:600;font-size:1rem;text-decoration:none;border:2px solid rgba(255,255,255,0.6);">Learn more</a>
      </div>
    </div>
    <figcaption style="position:absolute;bottom:8px;right:12px;color:rgba(255,255,255,0.6);font-size:0.72rem;">by JRS Uganda</figcaption>
  </section>

  <section style="background:var(--teal);color:#fff;padding:1.25rem 1.5rem;text-align:center;">
    <p style="margin:0;font-size:1.05rem;font-weight:600;">100 % of your donation goes directly to scholarships — zero to overhead.</p>
  </section>

  <section style="background:var(--paper-pure);padding:4rem 1.5rem;">
    <div class="max-w-5xl mx-auto">
      <p style="text-align:center;color:var(--stone);font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:3rem;">School year 2024/25</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:2rem;text-align:center;">
        {[
          { value: '24', label: 'Children supported' },
          { value: '18', label: 'Girls with scholarships' },
          { value: '100 %', label: 'School retention rate' },
          { value: '€ 900', label: 'per scholarship / year' },
        ].map(s => (
          <div>
            <p style="font-family:'Source Serif 4',Georgia,serif;font-size:3rem;font-weight:700;color:var(--gold);margin:0 0 0.5rem;">{s.value}</p>
            <p style="color:var(--stone);font-size:0.9rem;margin:0;">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="background:var(--ink);color:#fff;padding:4rem 1.5rem;text-align:center;">
    <h2 style="font-family:'Source Serif 4',Georgia,serif;font-size:2.2rem;font-weight:700;margin:0 0 1rem;">Be part of the solution.</h2>
    <p style="color:#b0aba0;font-size:1.05rem;margin:0 0 2rem;max-width:480px;margin-left:auto;margin-right:auto;">€ 75 per month funds a complete scholarship for one year.</p>
    <a href="/en/donate" style="background:var(--teal);color:#fff;padding:16px 36px;border-radius:8px;font-weight:700;font-size:1.1rem;text-decoration:none;display:inline-block;">Donate now</a>
  </section>

</Layout>
