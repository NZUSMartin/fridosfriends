---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Stat from '../../components/Stat.astro';
import Story from '../../components/Story.astro';
import PhotoBreak from '../../components/PhotoBreak.astro';
import PromiseBand from '../../components/PromiseBand.astro';
import CTABand from '../../components/CTABand.astro';
import MembershipCalculator from '../../components/MembershipCalculator.astro';
import ProgressThermometer from '../../components/ProgressThermometer.astro';
import { FUNDING } from '../../consts';

const betterplace = 'https://www.betterplace.org/de/projects/165916-schulstipendien-fuer-maedchen-in-uganda-bildung-ist-ihre-zukunft';

const steps = [
  {
    n: '1',
    title: 'JRS selects',
    body: 'Our partner on the ground, the Jesuit Refugee Service, knows the families in the Adjumani district and chooses the girls for whom a school place changes everything.',
  },
  {
    n: '2',
    title: 'We fund it — 100%',
    body: '€800 cover a full school year: school fees, materials, hygiene products, boarding and local mentoring. Every euro donated flows into scholarships.',
  },
  {
    n: '3',
    title: 'The girls stay in school',
    body: 'As of school year 2024/25, 100% of the children we support stay in school. An education no one can ever take away.',
  },
];

const multiplier = [
  {
    num: '3–6',
    title: 'Children per woman',
    body: 'Every educated woman directly influences three to six children — through what she passes on, earns and lives by.',
  },
  {
    num: '~40',
    title: 'Pupils per class',
    body: 'If a scholar becomes a teacher, she reaches around 40 children per class, year after year.',
  },
  {
    num: '150–300',
    title: 'Births per year',
    body: 'If she becomes a midwife, she attends 150 to 300 births a year — safely, in a region where that saves lives.',
  },
];
---

<Layout title="Education is their future" lang="en" path="/en/" spine="progress">

  <!-- 1. HERO -->
  <section class="hero section" data-hero>
    <div class="container">
      <div class="hero__grid">
        <div data-reveal-group>
          <Eyebrow text="Education is their future" />
          <h1 data-reveal>Education is the one investment no one can ever take away.</h1>
          <p class="lead" style="margin-top:var(--sp-5)" data-reveal>
            We fund school scholarships for girls in the Adjumani refugee district in
            northern Uganda — together with the Jesuit Refugee Service and in the spirit of
            Father Frido Pflüger. When you support one girl, you support a whole community.
          </p>
          <p class="hero__cost" data-reveal>Every gift counts — a full school year costs about <b>€800</b>.</p>
          <div class="btn-row" data-reveal>
            <a class="btn btn--primary" href="/en/donate">Get involved</a>
            <a class="btn btn--secondary" href="#how-it-works">Learn more</a>
          </div>
        </div>

        <figure class="figure hero__media" data-reveal>
          <img
            src="/images/start-adjumani-2.jpg"
            alt="Two students in front of their school in Adjumani, northern Uganda"
            width="1600" height="1067"
            style="object-fit:cover"
            fetchpriority="high" loading="eager" decoding="async"
          />
          <figcaption>Foto: JRS Uganda</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- 2. 100% PROMISE BAND (LOUD, dark) -->
  <PromiseBand lang="en" />

  <!-- 3. IMPACT / STATS — at a glance -->
  <section class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Impact" />
        <h2>Small numbers that change everything.</h2>
      </div>
      <div class="stats" data-reveal-group>
        <Stat figure="24"   countTo={24}  label="children supported" />
        <Stat figure="18"   countTo={18}  label="of them girls" />
        <Stat figure="100%" countTo={100} suffix="%" label="stay in school" />
        <Stat figure="€800" label="fund one school year" />
      </div>
      <p class="caption" style="margin-top:var(--sp-5);max-width:none" data-reveal>
        We primarily support girls, but occasionally also include gifted boys.
        <br />As of school year 2024/25
      </p>
    </div>
  </section>

  <!-- 3b. FUNDING TARGET — THERMOMETER -->
  <section class="section">
    <div class="container" data-reveal>
      <ProgressThermometer
        lang="en"
        raised={FUNDING.raised}
        goal={FUNDING.goal}
        year={FUNDING.year}
        asof={FUNDING.asof}
        sheetUrl={FUNDING.sheetUrl}
      />
    </div>
  </section>

  <!-- 4. ONE STORY — JO -->
  <section class="section">
    <div class="container">
      <Story
        image="/images/student-classroom-portrait.jpg"
        alt="Jo sits upright and confident in front of a blackboard"
        eyebrow="One of 24"
        heading="Jo would have been married at 15."
        quote="I want to become a midwife so mothers in my settlement can give birth safely."
        linkHref="/en/stories"
        linkLabel="More stories →"
      >
        <p>
          At around 15, Jo was on the verge of marriage. A scholarship let her stay in
          school — and changed her path. Today she is class representative.
        </p>
        <p>
          She wants to become a midwife: not just anywhere, but in her own settlement, so that
          mothers there can give birth safely. A school place that becomes a whole working life.
        </p>
      </Story>
    </div>
  </section>

  <!-- 5. PHOTO BREAK — MULTIPLIER -->
  <PhotoBreak
    src="/images/classroom-students.jpg"
    alt="A full classroom of attentive schoolgirls and schoolboys"
    eyebrow="The multiplier"
    heading="Educate one girl, and you change a whole community."
  />

  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <p class="lead">
          In refugee regions, girls' education has the highest long-term multiplier of all.
          Scholars go on to become nurses, midwives, teachers and civil servants —
          and each of them passes on what she has learned.
        </p>
      </div>
      <div class="grid-3" data-reveal-group>
        {multiplier.map((m) => (
          <article class="card card--story" data-reveal>
            <span class="card__num">{m.num}</span>
            <h3>{m.title}</h3>
            <p style="color:var(--stone);margin-top:var(--sp-3)">{m.body}</p>
          </article>
        ))}
      </div>
      <p class="caption" style="margin-top:var(--sp-5);max-width:none" data-reveal>
        In the Adjumani region, JRS-associated girls' education has reached around 30,000 girls over the years (source: JRS).
      </p>
    </div>
  </section>

  <!-- 6. WHAT WE BELIEVE IN -->
  <section class="section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="What we believe in" />
      <h2 data-reveal>What we believe in</h2>
      <p class="prose" style="margin-top:var(--sp-5)" data-reveal>
        A good education is becoming ever more of a privilege — we want to push back against
        that and help as many children as possible benefit from it. Our educational ideal is
        built on respect, equality of opportunity and the nurturing of every single child. We
        are convinced that education is far more than the transfer of knowledge: it strengthens
        self-confidence, a sense of responsibility and the ability to actively shape one's own
        future. Throughout, the dignity, individual talents and holistic development of each
        child remain at the heart of everything we do.
      </p>
    </div>
  </section>

  <!-- 7. HOW IT WORKS -->
  <section id="how-it-works" class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="How it works" />
        <h2>From contribution to school place — in three clear steps.</h2>
      </div>
      <div class="grid-3" data-reveal-group>
        {steps.map((s) => (
          <article class="card" data-reveal>
            <span class="card__num">{s.n}</span>
            <h3>{s.title}</h3>
            <p style="color:var(--stone);margin-top:var(--sp-3)">{s.body}</p>
          </article>
        ))}
      </div>
      <p style="margin-top:var(--sp-6)" data-reveal>
        <a class="link-tertiary" href="/en/project">See the full flow of funds and the €800 breakdown →</a>
      </p>
    </div>
  </section>

  <!-- 8. JOIN — CALCULATOR -->
  <section class="section">
    <div class="container">
      <div class="story">
        <div data-reveal>
          <Eyebrow text="Join us" />
          <h2>Become part of Frido&rsquo;s Friends.</h2>
          <p class="prose" style="margin-top:var(--sp-4);color:var(--stone)">
            A regular membership gives a girl planning security for the whole school year.
            Just €75 a month cover a complete school year — school fees, materials, hygiene
            products, boarding for those whose school commute is too far, and local mentoring.
          </p>
          <p class="prose" style="margin-top:var(--sp-4);color:var(--stone)">
            Prefer to give once? That works too — via betterplace.org, including a tax receipt.
            <a class="link-tertiary" href={betterplace} rel="noopener" target="_blank">Donate now →</a>
          </p>
        </div>
        <div data-reveal>
          <MembershipCalculator lang="en" />
        </div>
      </div>
    </div>
  </section>

  <!-- 9. FRIDO TEASER (dark) -->
  <section class="band band-dark section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="Why we do this" />
      <p class="lead" data-reveal>
        &ldquo;Accompaniment, not just aid.&rdquo; — Father Frido Pflüger SJ understood
        education in Adjumani as a service to human dignity. Seven friends from Kolleg
        St. Blasien carry on his work.
      </p>
      <p style="margin-top:var(--sp-5)" data-reveal>
        <a class="link-tertiary" href="/en/frido">Meet Father Frido →</a>
      </p>
    </div>
  </section>

  <!-- 10. DARK CTA BAND -->
  <CTABand
    heading="Accompaniment, not just aid."
    text="A school year costs €800. Your membership turns it into a reliable future for one girl."
    primaryHref="/en/donate"
    primaryLabel="Get involved"
    secondaryHref={betterplace}
    secondaryLabel="Donate now"
  />

</Layout>
