---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Privacy Policy" lang="en" currentPath="/en/privacy">
  <section style="padding:4rem 1.5rem;max-width:860px;margin:0 auto;">
    <h1 style="font-family:'Source Serif 4',Georgia,serif;font-size:2.2rem;font-weight:700;color:var(--ink);margin:0 0 2rem;">Privacy Policy</h1>
    <h2 style="font-family:'Source Serif 4',Georgia,serif;font-size:1.2rem;font-weight:700;margin:2rem 0 0.5rem;">Hosting</h2>
    <p style="color:var(--stone);line-height:1.8;">This website is hosted by Netlify, Inc. Netlify participates in the EU-US Data Privacy Framework (DPF).</p>
    <h2 style="font-family:'Source Serif 4',Georgia,serif;font-size:1.2rem;font-weight:700;margin:2rem 0 0.5rem;">Cookies</h2>
    <p style="color:var(--stone);line-height:1.8;">This website uses no cookies and no tracking or analytics services.</p>
    <h2 style="font-family:'Source Serif 4',Georgia,serif;font-size:1.2rem;font-weight:700;margin:2rem 0 0.5rem;">Supervisory Authority</h2>
    <p style="color:var(--stone);line-height:1.8;">Complaints may be directed to the LDI NRW (Landesbeauftragte für Datenschutz und Informationsfreiheit Nordrhein-Westfalen).</p>
  </section>
</Layout>
