---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import Story from '../../components/Story.astro';
import CTABand from '../../components/CTABand.astro';

const betterplace = 'https://www.betterplace.org/de/projects/165916-schulstipendien-fuer-maedchen-in-uganda-bildung-ist-ihre-zukunft';
---

<Layout
  title="Students"
  description="Voices from Adjumani: how a school place changed the path of two girls — told in keeping with the safeguarding standards of the Jesuit Refugee Service."
  lang="en"
  path="/en/stories"
  spine="progress"
>

  <!-- 1. INTRO -->
  <section class="section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="Scholars" />
      <h1 data-reveal>Voices from Adjumani</h1>
      <p class="lead" style="margin-top:var(--sp-5)" data-reveal>
        Behind every number stands a girl with a name, a path to school and a plan for her
        life. We tell two of those paths here — standing in for the 24 children we support
        in the Adjumani district of northern Uganda together with the Jesuit Refugee Service.
      </p>
      <p style="margin-top:var(--sp-4);color:var(--stone)" data-reveal>
        To protect the girls, we give only their first name and what they want to become.
        No surnames, no details about family or where they live, nothing that could identify
        them — these are the safeguarding standards of the Jesuit Refugee Service, and we hold
        to them.
      </p>
      <p style="margin-top:var(--sp-4);color:var(--stone)" data-reveal>
        Education gives South Sudanese refugee children in Uganda perspectives for the future —
        whether they stay on in Uganda or one day are able to return home to South Sudan.
      </p>
    </div>
  </section>

  <!-- 2. JO -->
  <section class="section">
    <div class="container">
      <Story
        image="/images/student-classroom-portrait.jpg"
        alt="Jo sits upright and self-assured in front of a blackboard"
        eyebrow="Scholar"
        heading="Jo would have been married at 15."
        quote="I want to become a midwife, so that mothers in my settlement can give birth safely."
      >
        <p>
          At around 15, Jo was close to marriage. In her settlement that is a familiar
          path — and for many girls the end of their schooling. A scholarship interrupted
          that path: it let Jo stay in school.
        </p>
        <p>
          Today she is class representative. She stands in front of her class, takes on
          responsibility and is one of those the younger children look up to.
        </p>
        <p>
          Her goal is concrete: she wants to become a midwife — not just anywhere, but in
          her own settlement, so that mothers there can give birth safely. A school place
          turns into a whole working life that saves the lives of others.
        </p>
      </Story>
      <p class="caption" style="margin-top:var(--sp-5)" data-reveal>
        For safeguarding reasons: first name and aspiration only, no identifying details (JRS safeguarding standards).
      </p>
    </div>
  </section>

  <!-- 3. MARY -->
  <section class="band band-pure section">
    <div class="container">
      <Story
        image="/images/student-writing-closeup.jpg"
        alt="A student's hands write with concentration in an exercise book"
        eyebrow="Scholar"
        heading="Mary could not read when she arrived."
        quote="I want to teach, so the next children have a teacher who knows life in the settlement."
      >
        <p>
          Mary fled South Sudan with her grandmother. When she arrived in Adjumani, she
          could not read. Her mother had left school at twelve — because of an early
          marriage. Mary is the first in her family to attend secondary school.
        </p>
        <p>
          By now she is among the best in her class. She loves mathematics and biology and
          already passes on what she has learned: she helps the younger children with their
          studies before she sits down to her own work.
        </p>
        <p>
          She wants to become a teacher — so that the children who come after her have a
          teacher who understands life in the settlement from her own experience and trusts
          that their path, too, can lead forward.
        </p>
      </Story>
      <p class="caption" style="margin-top:var(--sp-5)" data-reveal>
        For safeguarding reasons: first name and aspiration only, no identifying details (JRS safeguarding standards).
      </p>
    </div>
  </section>

  <!-- 3b. gift cross-link -->
  <section class="section section--tight">
    <div class="container container-text" style="text-align:center" data-reveal>
      <p class="prose" style="color:var(--stone);margin:0">
        Give a story like this one —
        <a class="link-tertiary" href="/en/gift">give education in someone&rsquo;s name →</a>
      </p>
    </div>
  </section>

  <!-- 4. CTA -->
  <CTABand
    heading="Give the next story a good ending."
    text="One school year costs €800. Your membership turns a school place into a dependable future — for one more girl in Adjumani."
    primaryHref="/en/donate"
    primaryLabel="Get involved"
    secondaryHref={betterplace}
    secondaryLabel="Donate now"
  />

</Layout>
