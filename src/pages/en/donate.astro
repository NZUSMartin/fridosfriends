---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import MembershipForm from '../../components/MembershipForm.astro';

const betterplace = 'https://www.betterplace.org/de/projects/165916-schulstipendien-fuer-maedchen-in-uganda-bildung-ist-ihre-zukunft';

const trust = [
  {
    title: '100% goes into scholarships',
    body: 'Administrative costs are covered privately by the founding members — anchored in our statutes.',
  },
  {
    title: 'Registered charity',
    body: 'Frido’s Friends e.V., registered with the district court (Amtsgericht) of Cologne.',
  },
  {
    title: 'Annual accountability report',
    body: 'We disclose how many girls receive scholarships and where every euro goes.',
  },
  {
    title: 'Partner with safeguarding standards',
    body: 'On the ground, the Jesuit Refugee Service accompanies the girls — with clear safeguarding standards.',
  },
  {
    title: 'Tax receipt included',
    body: 'Betterplace issues your donation receipt (Zuwendungsbestätigung) automatically.',
  },
  {
    title: 'A board, not an NGO apparatus',
    body: 'Deliberately small, transparent, efficient — no large NGO structure.',
  },
];
---

<Layout
  title="Get involved"
  description="Become a member of Frido's Friends e.V. and fund a school year for a girl in northern Uganda. 100% of your donation goes into scholarships."
  lang="en"
  path="/en/donate"
  spine="progress"
>

  <!-- (a) INTRO -->
  <section class="section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="Get involved" />
      <h1 data-reveal>Your support works directly.</h1>
      <p class="lead" style="margin-top:var(--sp-5)" data-reveal>
        100% of your donation goes straight into school scholarships for girls in the Adjumani
        refugee settlement — administrative costs are covered privately by the founding members.
        Not a single euro is lost. You decide how you help: as a member, month after month, with a
        one-off gift, or by bank transfer.
      </p>
    </div>
  </section>

  <!-- (b)+(c) MEMBERSHIP (dominant) + TRUST CLUSTER -->
  <section class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Become a member" />
        <h2>One membership carries a full school year.</h2>
      </div>

      <div class="join-grid">
        <!-- Ask column: real membership application form (Netlify → Vorstand) -->
        <div class="join-ask" data-reveal-group>
          <div data-reveal>
            <MembershipForm lang="en" />
          </div>
        </div>

        <!-- Trust cluster, ask-adjacent -->
        <aside class="card join-trust" aria-label="Trust and transparency" data-reveal>
          <Eyebrow text="Why you can trust us" />
          <ul class="join-trust__list">
            {trust.map((t) => (
              <li>
                <h3 class="h4">{t.title}</h3>
                <p>{t.body}</p>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- (d)+(e) ONE-OFF GIFT + BANK TRANSFER -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Other ways to give" />
        <h2>Prefer a one-off gift or a bank transfer?</h2>
      </div>

      <div class="give-grid" data-reveal-group>
        <!-- (d) One-off gift -->
        <article class="card" data-reveal>
          <Eyebrow text="One-off gift" />
          <p class="give-amount"><b>€900</b> = a full school year.</p>
          <p style="color:var(--stone)">
            School fees, school materials, hygiene products including menstrual supplies, boarding
            and local mentoring — a single amount that carries a whole year. Every contribution
            helps, large or small.
          </p>
          <a class="btn btn--secondary give-card__btn" href={betterplace} rel="noopener" target="_blank">
            Give a one-off gift via betterplace.org
          </a>
        </article>

        <!-- (e) Direct bank transfer -->
        <article class="card" data-reveal>
          <Eyebrow text="Direct bank transfer" />
          <p style="color:var(--stone);margin-bottom:var(--sp-4)">
            You can also transfer directly to our association account:
          </p>
          <div class="bank-grid">
            <dl class="bank">
              <dt>Recipient</dt>
              <dd>Frido’s Friends e.V.</dd>
              <dt>IBAN</dt>
              <dd>DE44 6805 2230 0000 2055 26</dd>
              <dt>BIC</dt>
              <dd>SOLADES1STB</dd>
              <dt>Bank</dt>
              <dd>Sparkasse St. Blasien</dd>
              <dt>Reference</dt>
              <dd>Spende Schulstipendien</dd>
            </dl>
            <figure class="figure bank-qr">
              <img
                src="/images/sepa-qr.svg"
                alt="SEPA QR code for a donation to Frido's Friends e.V."
                width="180" height="180"
                loading="lazy" decoding="async"
              />
              <figcaption>SEPA QR code to scan</figcaption>
            </figure>
          </div>
          <p class="caption" style="margin-top:var(--sp-5)">
            For amounts up to €300, your bank statement suffices as proof of donation. For larger
            amounts we are glad to issue a Zuwendungsbestätigung — just write to us at
            <a class="link-tertiary" href="mailto:vorstand@fridosfriends.de">vorstand@fridosfriends.de</a>.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- (f) MORE WAYS TO HELP -->
  <section class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="More than donating" />
        <h2>More ways to help.</h2>
      </div>

      <div class="grid-3" data-reveal-group>
        <article class="card card--story" data-reveal>
          <h3>Spread the word</h3>
          <p style="color:var(--stone);margin-top:var(--sp-3)">
            Tell others about Frido’s Friends — in your family, among friends, in your community.
            A personal recommendation opens more doors than any advertisement.
          </p>
        </article>

        <article class="card card--story" data-reveal>
          <h3>Bring your network</h3>
          <p style="color:var(--stone);margin-top:var(--sp-3)">
            Do you know people or companies who would like to support girls’ education? Connect us.
            Write to
            <a class="link-tertiary" href="mailto:vorstand@fridosfriends.de">vorstand@fridosfriends.de</a>.
          </p>
        </article>

        <article class="card card--story" data-reveal>
          <h3>Newsletter</h3>
          <p style="color:var(--stone);margin-top:var(--sp-3)">
            Stay close: we report on how the girls we support are doing. Sign up by email at
            <a class="link-tertiary" href="mailto:vorstand@fridosfriends.de?subject=Newsletter">vorstand@fridosfriends.de</a>.
          </p>
        </article>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Membership ask (calculator + CTA) beside the trust cluster — page-local layout only */
  .join-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .join-grid { grid-template-columns: 1.15fr 0.85fr; gap: var(--sp-8); }
  }
  .join-ask > * + * { margin-top: var(--sp-6); }

  .join-cta { text-align: center; }
  .join-cta__btn { width: 100%; }
  .join-cta__note { margin-top: var(--sp-4); }

  .join-trust__list {
    list-style: none;
    margin: var(--sp-2) 0 0;
    padding: 0;
    display: grid;
    gap: var(--sp-5);
  }
  .join-trust__list li { max-width: none; }
  .join-trust__list p { color: var(--stone); margin-top: var(--sp-1); }

  /* One-off gift + bank-transfer cards */
  .give-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    align-items: start;
  }
  @media (min-width: 768px) {
    .give-grid { grid-template-columns: 1fr 1fr; gap: var(--sp-7); }
  }
  .give-amount {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: var(--step-2);
    color: var(--ink);
    margin: var(--sp-2) 0 var(--sp-4);
  }
  .give-amount b { color: var(--gold); font-weight: 600; }
  .give-card__btn { margin-top: var(--sp-5); }

  .bank-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    align-items: start;
  }
  @media (min-width: 480px) {
    .bank-grid { grid-template-columns: 1fr auto; }
  }
  .bank-grid .bank { margin: 0; }
  .bank {
    font-size: var(--step-0);
    line-height: 1.6;
  }
  .bank dt {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--stone);
  }
  .bank dd {
    margin: 0 0 var(--sp-4);
    color: var(--ink);
  }
  .bank dd:last-child { margin-bottom: 0; }
  .bank-qr { text-align: center; }
  .bank-qr img {
    width: 180px;
    max-width: 100%;
    height: auto;
    border-radius: var(--r-card);
    border: 1px solid var(--line);
    background: var(--paper-pure);
  }
</style>
