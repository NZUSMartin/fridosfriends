---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Donate" lang="en" currentPath="/en/donate">
  <section style="padding:4rem 1.5rem;max-width:860px;margin:0 auto;text-align:center;">
    <p style="color:var(--gold);font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.5rem;">Donate</p>
    <h1 style="font-family:'Source Serif 4',Georgia,serif;font-size:clamp(2rem,4vw,2.8rem);font-weight:700;color:var(--ink);margin:0 0 1rem;">Your donation has direct impact.</h1>
    <p style="color:var(--stone);font-size:1.05rem;line-height:1.8;max-width:560px;margin:0 auto 3rem;">100 % of your donation goes to scholarships. Bank transfer:</p>
    <div style="background:var(--paper-pure);border-radius:10px;padding:2rem;border:1px solid var(--line);text-align:left;max-width:480px;margin:0 auto 2rem;">
      <table style="width:100%;border-collapse:collapse;">
        <tr style="border-bottom:1px solid var(--line);"><td style="padding:10px 0;color:var(--stone);font-size:0.85rem;width:40%;">Recipient</td><td style="padding:10px 0;font-weight:600;">Frido's Friends e.V.</td></tr>
        <tr style="border-bottom:1px solid var(--line);"><td style="padding:10px 0;color:var(--stone);font-size:0.85rem;">IBAN</td><td style="padding:10px 0;font-weight:600;">DE44 6805 2230 0000 2055 26</td></tr>
        <tr style="border-bottom:1px solid var(--line);"><td style="padding:10px 0;color:var(--stone);font-size:0.85rem;">BIC</td><td style="padding:10px 0;font-weight:600;">SOLADES1STB</td></tr>
        <tr style="border-bottom:1px solid var(--line);"><td style="padding:10px 0;color:var(--stone);font-size:0.85rem;">Bank</td><td style="padding:10px 0;font-weight:600;">Sparkasse Bodensee-Hegau</td></tr>
        <tr><td style="padding:10px 0;color:var(--stone);font-size:0.85rem;">Reference</td><td style="padding:10px 0;font-weight:600;">Donation scholarships Uganda</td></tr>
      </table>
    </div>
    <div style="text-align:center;background:var(--paper);border-radius:10px;padding:2rem;border:1px solid var(--line);max-width:320px;margin:0 auto;">
      <p style="color:var(--stone);font-size:0.9rem;margin:0 0 1rem;">SEPA QR Code</p>
      <img src="/images/sepa-qr.svg" alt="SEPA QR code for Frido's Friends donation" style="width:160px;height:160px;display:inline-block;" />
    </div>
  </section>
</Layout>
