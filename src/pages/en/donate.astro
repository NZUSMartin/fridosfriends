---
import Layout from '../../layouts/Layout.astro';
import Eyebrow from '../../components/Eyebrow.astro';
import MembershipForm from '../../components/MembershipForm.astro';
import ProgressThermometer from '../../components/ProgressThermometer.astro';
import { FUNDING, BETTERPLACE, BETTERPLACE_SHORT, PAYPAL_DONATE, PAYPAL_SUBSCRIBE } from '../../consts';

const IBAN = 'DE44 6805 2230 0000 2055 26';

const trust = [
  {
    title: '100% goes into scholarships',
    body: 'Administrative costs are covered privately by the founding members — anchored in our statutes.',
  },
  {
    title: 'Registered charity',
    body: 'Frido’s Friends e.V., registered with the district court (Amtsgericht) of Cologne.',
  },
  {
    title: 'Annual accountability report',
    body: 'We disclose how many girls receive scholarships and where every euro goes.',
  },
  {
    title: 'Partner with safeguarding standards',
    body: 'On the ground, the Jesuit Refugee Service accompanies the girls — with clear safeguarding standards.',
  },
  {
    title: 'Tax receipt included',
    body: 'Betterplace issues your donation receipt (Zuwendungsbestätigung) automatically.',
  },
  {
    title: 'A board, not an NGO apparatus',
    body: 'Deliberately small, transparent, efficient — no large NGO structure.',
  },
];
---

<Layout
  title="Donate"
  description="Donate to Frido's Friends e.V. or become a member and fund a school year for a girl in northern Uganda. 100% of your donation goes into scholarships."
  lang="en"
  path="/en/donate"
  spine="progress"
>

  <!-- (1) INTRO -->
  <section class="section">
    <div class="container container-text" data-reveal-group>
      <Eyebrow text="Get involved" />
      <h1 data-reveal>Your support works directly.</h1>
      <p class="lead" style="margin-top:var(--sp-5)" data-reveal>
        100% of your donation goes straight into school scholarships for girls in the Adjumani
        refugee settlement — administrative costs are covered privately by the founding members.
        Not a single euro is lost. You decide how you help: with a one-off gift, or as a member,
        month after month.
      </p>
    </div>
  </section>

  <!-- (2) FUNDING THERMOMETER -->
  <section class="section section--tight">
    <div class="container container-text">
      <div data-reveal>
        <ProgressThermometer
          lang="en"
          raised={FUNDING.raised}
          goal={FUNDING.goal}
          year={FUNDING.year}
          asof={FUNDING.asof}
          sheetUrl={FUNDING.sheetUrl}
        />
      </div>
    </div>
  </section>

  <!-- (3) DONATE — one-off (FIRST) -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Donate" />
        <h2>Every gift counts — no matter the size.</h2>
        <p class="give-lead" data-reveal>
          For reference: one school year costs around €800 per girl — but every contribution
          helps, including small and recurring ones.
        </p>
      </div>

      <div class="give-grid" data-reveal-group>
        <!-- One-time payment options -->
        <article class="card" data-reveal>
          <Eyebrow text="Give online" />
          <p style="color:var(--stone);margin:var(--sp-3) 0 var(--sp-5)">
            Quick and secure via PayPal or betterplace.org. Every amount arrives straight away.
          </p>
          <div class="pay-row">
            <a class="btn btn--primary" href={PAYPAL_DONATE} rel="noopener" target="_blank">
              Donate with PayPal
            </a>
            <a class="pay-badge" href={PAYPAL_DONATE} rel="noopener" target="_blank" aria-label="PayPal">
              <img src="/images/paypal-logo.png" alt="PayPal" width="136" height="34" loading="lazy" />
            </a>
          </div>
          <div class="pay-row" style="margin-top:var(--sp-5)">
            <a class="btn btn--secondary" href={BETTERPLACE} rel="noopener" target="_blank">
              Donate with betterplace
            </a>
            <a class="pay-badge" href={BETTERPLACE_SHORT} rel="noopener" target="_blank" aria-label="betterplace.org">
              <img src="/images/betterplace-logo.png" alt="betterplace.org" width="128" height="19" loading="lazy" />
            </a>
          </div>
        </article>

        <!-- Direct bank transfer -->
        <article class="card" data-reveal>
          <Eyebrow text="Direct bank transfer" />
          <p style="color:var(--stone);margin:var(--sp-3) 0 var(--sp-4)">
            You can also transfer directly to our association account:
          </p>
          <div class="bank-grid">
            <dl class="bank">
              <dt>Recipient</dt>
              <dd>Frido’s Friends e.V.</dd>
              <dt>IBAN</dt>
              <dd>{IBAN}</dd>
              <dt>BIC</dt>
              <dd>SOLADES1STB</dd>
              <dt>Bank</dt>
              <dd>Sparkasse St. Blasien</dd>
              <dt>Reference</dt>
              <dd>Spende Schulstipendien</dd>
            </dl>
            <figure class="figure bank-qr">
              <img
                src="/images/sepa-qr.svg"
                alt="SEPA QR code for a donation to Frido's Friends e.V."
                width="180" height="180"
                loading="lazy" decoding="async"
              />
              <p class="qr-note">
                Please scan the QR code with your banking app — and please don't forget your email
                address; we would love to send you a donation receipt.
              </p>
            </figure>
          </div>
          <p class="caption" style="margin-top:var(--sp-5)">
            For every donation we will issue a receipt on request; up to €300 the tax office accepts
            your bank statement as proof.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- (4) BECOME A MEMBER — recurring (SECOND, equal weight) + (5) TRUST CLUSTER -->
  <section class="band band-pure section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="Become a member" />
        <h2>Become a member — give regularly.</h2>
        <p class="give-lead" data-reveal>
          Membership gives us planning security: your support becomes reliable, ongoing funding we
          can build on year after year.
        </p>
      </div>

      <div class="join-grid">
        <!-- Ask column: real membership application form (Netlify → Vorstand) -->
        <div class="join-ask" data-reveal-group>
          <div data-reveal>
            <MembershipForm lang="en" />
          </div>

          <!-- Recurring options -->
          <div class="card" data-reveal>
            <Eyebrow text="Give regularly" />
            <h3 class="h4" style="margin-top:var(--sp-3)">SEPA standing order</h3>
            <p style="color:var(--stone);margin-top:var(--sp-2)">
              Set up a standing order with your bank to our account (e.g. €25 / €50 / €75 per
              month), reference “Mitgliedsbeitrag” — that is all it takes to turn your gift into
              reliable, ongoing support.
            </p>
            <dl class="bank" style="margin-top:var(--sp-4)">
              <dt>Recipient</dt>
              <dd>Frido’s Friends e.V.</dd>
              <dt>IBAN</dt>
              <dd>{IBAN}</dd>
              <dt>BIC</dt>
              <dd>SOLADES1STB</dd>
              <dt>Reference</dt>
              <dd>Mitgliedsbeitrag</dd>
            </dl>

            <h3 class="h4" style="margin-top:var(--sp-6)">PayPal</h3>
            {PAYPAL_SUBSCRIBE ? (
              <a class="btn btn--primary" style="margin-top:var(--sp-3)" href={PAYPAL_SUBSCRIBE} rel="noopener" target="_blank">
                Monthly with PayPal
              </a>
            ) : (
              <p class="caption" style="margin-top:var(--sp-3)">PayPal subscription coming soon.</p>
            )}

            <p class="caption" style="margin-top:var(--sp-5)">
              <a class="link-tertiary" href="/en/promise">How we keep the 100% promise →</a>
            </p>
          </div>
        </div>

        <!-- Trust cluster, ask-adjacent -->
        <aside class="card join-trust" aria-label="Trust and transparency" data-reveal>
          <Eyebrow text="Why you can trust us" />
          <ul class="join-trust__list">
            {trust.map((t) => (
              <li>
                <h3 class="h4">{t.title}</h3>
                <p>{t.body}</p>
              </li>
            ))}
          </ul>
        </aside>
      </div>
    </div>
  </section>

  <!-- (5) MORE WAYS TO HELP -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <Eyebrow text="More than donating" />
        <h2>More ways to help.</h2>
      </div>

      <div class="grid-3" data-reveal-group>
        <article class="card card--story" data-reveal>
          <h3>Spread the word</h3>
          <p style="color:var(--stone);margin-top:var(--sp-3)">
            Tell others about Frido’s Friends — in your family, among friends, in your community.
            A personal recommendation opens more doors than any advertisement.
          </p>
        </article>

        <article class="card card--story" data-reveal>
          <h3>Bring your network</h3>
          <p style="color:var(--stone);margin-top:var(--sp-3)">
            Do you know people or companies who would like to support girls’ education? Connect us.
            Write to
            <a class="link-tertiary" href="mailto:vorstand@fridosfriends.de">vorstand@fridosfriends.de</a>.
          </p>
        </article>

        <article class="card card--story" data-reveal>
          <h3>Newsletter</h3>
          <p style="color:var(--stone);margin-top:var(--sp-3)">
            Stay close: we report on how the girls we support are doing. Sign up by email at
            <a class="link-tertiary" href="mailto:vorstand@fridosfriends.de?subject=Newsletter">vorstand@fridosfriends.de</a>.
          </p>
        </article>
      </div>
    </div>
  </section>

</Layout>

<style>
  .section--tight { padding-top: 0; }

  .give-lead {
    color: var(--stone);
    font-size: var(--step-0);
    margin-top: var(--sp-3);
  }

  /* Donate: online options beside bank transfer */
  .give-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    align-items: start;
  }
  @media (min-width: 768px) {
    .give-grid { grid-template-columns: 1fr 1fr; gap: var(--sp-7); }
  }

  /* Membership ask beside the trust cluster — page-local layout only */
  .join-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .join-grid { grid-template-columns: 1.15fr 0.85fr; gap: var(--sp-8); }
  }
  .join-ask > * + * { margin-top: var(--sp-6); }

  .join-trust__list {
    list-style: none;
    margin: var(--sp-2) 0 0;
    padding: 0;
    display: grid;
    gap: var(--sp-5);
  }
  .join-trust__list li { max-width: none; }
  .join-trust__list p { color: var(--stone); margin-top: var(--sp-1); }

  .bank-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-5);
    align-items: start;
  }
  @media (min-width: 480px) {
    .bank-grid { grid-template-columns: 1fr auto; }
  }
  .bank-grid .bank { margin: 0; }
  .bank {
    font-size: var(--step-0);
    line-height: 1.6;
  }
  .bank dt {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--step--1);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--stone);
  }
  .bank dd {
    margin: 0 0 var(--sp-4);
    color: var(--ink);
  }
  .bank dd:last-child { margin-bottom: 0; }
  .bank-qr { text-align: center; }
  .bank-qr img {
    width: 180px;
    max-width: 100%;
    height: auto;
    border-radius: var(--r-card);
    border: 1px solid var(--line);
    background: var(--paper-pure);
  }
</style>
