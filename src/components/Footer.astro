---
interface Props {
  lang?: 'de' | 'en';
}
const { lang = 'de' } = Astro.props;
---
<footer style="background:var(--ink);color:#e8e4dc;margin-top:4rem;padding:3rem 1rem 2rem;">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
    <div>
      <p style="font-family:'Source Serif 4',Georgia,serif;font-size:1.1rem;font-weight:700;margin-bottom:0.5rem;">Frido's Friends e.V.</p>
      <p style="font-size:0.875rem;color:#b0aba0;line-height:1.7;">
        Gemarkenstraße 12<br>51069 Köln<br>
        <a href="mailto:martin.hirt@cassandra.ceo" style="color:#b0aba0;">martin.hirt@cassandra.ceo</a>
      </p>
    </div>
    <div>
      <p style="font-weight:600;margin-bottom:0.5rem;font-size:0.875rem;color:var(--gold-soft);">{lang === 'de' ? 'Navigation' : 'Navigation'}</p>
      {lang === 'de' ? (
        <ul style="list-style:none;padding:0;margin:0;font-size:0.875rem;line-height:2;">
          <li><a href="/projekt" style="color:#b0aba0;text-decoration:none;">Das Projekt</a></li>
          <li><a href="/geschichten" style="color:#b0aba0;text-decoration:none;">Geschichten</a></li>
          <li><a href="/frido" style="color:#b0aba0;text-decoration:none;">Pater Frido</a></li>
          <li><a href="/ueber-uns" style="color:#b0aba0;text-decoration:none;">Über uns</a></li>
          <li><a href="/mitmachen" style="color:#b0aba0;text-decoration:none;">Mitmachen</a></li>
        </ul>
      ) : (
        <ul style="list-style:none;padding:0;margin:0;font-size:0.875rem;line-height:2;">
          <li><a href="/en/project" style="color:#b0aba0;text-decoration:none;">The Project</a></li>
          <li><a href="/en/stories" style="color:#b0aba0;text-decoration:none;">Stories</a></li>
          <li><a href="/en/frido" style="color:#b0aba0;text-decoration:none;">Father Frido</a></li>
          <li><a href="/en/about" style="color:#b0aba0;text-decoration:none;">About us</a></li>
          <li><a href="/en/donate" style="color:#b0aba0;text-decoration:none;">Donate</a></li>
        </ul>
      )}
    </div>
    <div>
      <p style="font-weight:600;margin-bottom:0.5rem;font-size:0.875rem;color:var(--gold-soft);">{lang === 'de' ? 'Rechtliches' : 'Legal'}</p>
      <ul style="list-style:none;padding:0;margin:0;font-size:0.875rem;line-height:2;">
        <li><a href="/impressum" style="color:#b0aba0;text-decoration:none;">{lang === 'de' ? 'Impressum' : 'Imprint'}</a></li>
        <li><a href="/datenschutz" style="color:#b0aba0;text-decoration:none;">{lang === 'de' ? 'Datenschutz' : 'Privacy Policy'}</a></li>
      </ul>
      <p style="font-size:0.75rem;color:#6b6660;margin-top:1.5rem;">© 2025 Frido's Friends e.V.<br>{lang === 'de' ? 'Eingetragen beim Amtsgericht Köln' : 'Registered at Amtsgericht Köln'}</p>
    </div>
  </div>
</footer>
