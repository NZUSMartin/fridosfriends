---
/**
 * Footer.astro — ink background. Brand + mission, navigation, legal, Spendenkonto
 * (IBAN/BIC/Sparkasse St. Blasien) + BetterPlace link, trust line, in-memoriam line.
 *
 * Props:
 *   lang  'de' | 'en'  — language (default 'de')
 */
import Logo from './Logo.astro';

interface Props { lang?: 'de' | 'en'; }
const { lang = 'de' } = Astro.props;
const isEn = lang === 'en';
const year = new Date().getFullYear();

const betterplace = 'https://www.betterplace.org/de/projects/165916-schulstipendien-fuer-maedchen-in-uganda-bildung-ist-ihre-zukunft';

const navDe = [
  { href: '/projekt',     label: 'Das Projekt' },
  { href: '/geschichten', label: 'Stipendiatinnen' },
  { href: '/frido',       label: 'Pater Frido' },
  { href: '/mitmachen',   label: 'Mitmachen' },
  { href: '/ueber-uns',   label: 'Über uns' },
];
const navEn = [
  { href: '/en/project', label: 'The Project' },
  { href: '/en/stories', label: 'Scholars' },
  { href: '/en/frido',   label: 'Father Frido' },
  { href: '/en/donate',  label: 'Get involved' },
  { href: '/en/about',   label: 'About us' },
];
const nav = isEn ? navEn : navDe;
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__grid">

      <!-- Brand + mission + address -->
      <div>
        <span class="footer-brand">
          <Logo height={30} variant="icon" />
          <span class="footer-brand__name">Frido&rsquo;s Friends e.V.</span>
        </span>
        <p>
          {isEn
            ? 'Secondary-school scholarships for girls in the Adjumani refugee district of northern Uganda — together with the Jesuit Refugee Service (JRS).'
            : 'Schulstipendien für Mädchen im Flüchtlingsbezirk Adjumani im Norden Ugandas — gemeinsam mit dem Jesuit Refugee Service (JRS).'}
        </p>
        <p class="bank" style="margin-top:var(--sp-4)">
          Gemarkenstraße 12, 51069 Köln<br />
          <a href="mailto:vorstand@fridosfriends.de">vorstand@fridosfriends.de</a>
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3>{isEn ? 'Navigation' : 'Navigation'}</h3>
        <ul>
          {nav.map((item) => (<li><a href={item.href}>{item.label}</a></li>))}
          <li>
            <a href={isEn ? '/en/imprint' : '/impressum'}>{isEn ? 'Imprint' : 'Impressum'}</a>
          </li>
          <li>
            <a href={isEn ? '/en/privacy' : '/datenschutz'}>{isEn ? 'Privacy' : 'Datenschutz'}</a>
          </li>
        </ul>
      </div>

      <!-- Spendenkonto -->
      <div>
        <h3>{isEn ? 'Donation account' : 'Spendenkonto'}</h3>
        <dl class="bank">
          <dt>{isEn ? 'Recipient' : 'Empfänger'}</dt>
          <dd>Frido&rsquo;s Friends e.V.</dd>
          <dt>IBAN</dt>
          <dd>DE44&nbsp;6805&nbsp;2230&nbsp;0000&nbsp;2055&nbsp;26</dd>
          <dt>BIC</dt>
          <dd>SOLADES1STB</dd>
          <dt>{isEn ? 'Bank' : 'Bank'}</dt>
          <dd>Sparkasse St.&nbsp;Blasien</dd>
        </dl>
        <div class="footer-pay">
          <h3>{isEn ? 'Ways to give' : 'So können Sie spenden'}</h3>
          <div class="pay-badges">
            <a class="pay-badge" href="https://www.betterplace.org/de/projects/165916" rel="noopener" target="_blank" aria-label="betterplace.org">
              <img src="/images/betterplace-logo.png" alt="betterplace.org" width="128" height="19" loading="lazy" />
            </a>
            <a class="pay-badge" href="https://www.paypal.com/donate/?hosted_button_id=R94VT44NWJ7QY" rel="noopener" target="_blank" aria-label="PayPal">
              <img src="/images/paypal-logo.png" alt="PayPal" width="136" height="34" loading="lazy" />
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="legal">
        {isEn
          ? `Frido’s Friends e.V. · Registered charity (gemeinnützig anerkannt) · Amtsgericht Köln · founded 15 August 2025 · © ${year}`
          : `Frido’s Friends e.V. · Gemeinnützig anerkannt · Amtsgericht Köln · gegründet 15. August 2025 · © ${year}`}
      </p>
      <p class="footer-memoriam">
        {isEn ? 'In memory of Father Frido Pflüger SJ (1947–2021)' : 'Im Andenken an Pater Frido Pflüger SJ (1947–2021)'}
      </p>
    </div>
  </div>
</footer>
