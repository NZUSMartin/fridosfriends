---
/**
 * PromiseBand.astro — the LOUD dark "100% promise" band (DESIGN.md §4.11 / homepage §2).
 * Dark ink background; the gold spine runs through it (no brightness toggle — see DESIGN.md §5).
 *
 * Props:
 *   lang  'de' | 'en'  — language (default 'de'); copy is fixed to the immutable promise.
 */
import Eyebrow from './Eyebrow.astro';
interface Props { lang?: 'de' | 'en'; }
const { lang = 'de' } = Astro.props;
const isEn = lang === 'en';

const trustDe = ['Gemeinnützig', 'Spendenquittung', 'Partner JRS'];
const trustEn = ['Registered charity', 'Tax receipt', 'Partner JRS'];
const trust = isEn ? trustEn : trustDe;
---
<section class="band band-dark section promise">
  <div class="container" data-reveal-group>
    <Eyebrow text={isEn ? 'Our promise' : 'Unser Versprechen'} center />
    <h2 class="promise__head" data-reveal>
      <span class="promise__pct">100&nbsp;%</span>
      {isEn ? ' of your donation go directly into scholarships.' : ' Ihrer Spende fließen direkt in Stipendien.'}
    </h2>
    <p data-reveal>
      {isEn
        ? 'Administrative costs are covered privately by the founding members — anchored in our statutes.'
        : 'Verwaltungskosten tragen die Gründungsmitglieder privat — in der Satzung verankert.'}
    </p>
    <ul class="trust-row trust-row--dark" data-reveal>
      {trust.map((t) => (<li>{t}</li>))}
    </ul>
  </div>
</section>
