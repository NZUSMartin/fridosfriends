---
/**
 * Logo.astro — the real Frido's Friends mark (Jesuit double-shaft patriarchal cross),
 * recoloured to gold with transparency from the original logo artwork.
 * Raster on purpose: the exact provided design, not a redrawing.
 *
 * Props:
 *   size   number  — rendered width in px (default 40). Height scales by the artwork ratio.
 *   color? string  — accepted for backwards compatibility; ignored (the mark is gold).
 *   class? string
 */
interface Props { size?: number; color?: string; class?: string; }
const { size = 40, class: className = 'brand__mark' } = Astro.props;
const ratio = 558 / 336; // intrinsic logo-gold.png aspect (height / width)
const h = Math.round(size * ratio);
---
<img
  class={className}
  src="/images/logo-gold.png"
  width={size}
  height={h}
  alt=""
  aria-hidden="true"
  decoding="async"
  style={`width:${size}px;height:auto;display:block`}
/>
