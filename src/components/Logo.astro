---
/**
 * Logo.astro — the Frido's Friends mark (gold figure rising from an open book).
 * Recoloured/keyed to transparency from the supplied artwork; raster on purpose.
 *
 * Props:
 *   height   number          — rendered height in px (default 40); width scales by ratio.
 *   variant  'full' | 'icon' — full lockup (icon + wordmark) or icon only (default 'full').
 *   class?   string
 */
interface Props { height?: number; variant?: 'full' | 'icon'; class?: string; }
const { height = 40, variant = 'full', class: className = 'brand__mark' } = Astro.props;
const isIcon = variant === 'icon';
const src = isIcon ? '/images/logo-icon.png' : '/images/logo-full.png';
const ratioWH = isIcon ? 315 / 258 : 772 / 262; // width / height of the artwork
const w = Math.round(height * ratioWH);
---
<img
  class={className}
  src={src}
  width={w}
  height={height}
  alt=""
  aria-hidden="true"
  decoding="async"
  style={`height:${height}px;width:auto;display:block`}
/>
