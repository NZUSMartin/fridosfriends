---
/**
 * Header.astro — sticky, persistent. Gold logo + wordmark (left), nav (center/right),
 * DE/EN switch + teal "Mitglied werden" CTA (right), accessible mobile hamburger drawer.
 *
 * Props:
 *   lang  'de' | 'en'  — language (default 'de')
 *   path  string       — current pathname for active-item highlight (e.g. '/projekt', '/en/project')
 */
import Logo from './Logo.astro';

interface Props { lang?: 'de' | 'en'; path?: string; }
const { lang = 'de', path = '' } = Astro.props;
const isEn = lang === 'en';

const home = isEn ? '/en/' : '/';
const joinHref = isEn ? '/en/donate' : '/mitmachen';
const joinLabel = isEn ? 'Become a member' : 'Mitglied werden';
const altHref = isEn ? '/' : '/en/';
const altLabel = isEn ? 'DE' : 'EN';

const navDe = [
  { href: '/projekt',     label: 'Das Projekt' },
  { href: '/geschichten', label: 'Stipendiatinnen' },
  { href: '/frido',       label: 'Pater Frido' },
  { href: '/ueber-uns',   label: 'Über uns' },
];
const navEn = [
  { href: '/en/project', label: 'The Project' },
  { href: '/en/stories', label: 'Scholars' },
  { href: '/en/frido',   label: 'Father Frido' },
  { href: '/en/about',   label: 'About us' },
];
const nav = isEn ? navEn : navDe;

// normalise trailing slash for comparison
const norm = (p: string) => (p.length > 1 ? p.replace(/\/$/, '') : p);
const cur = norm(path);
const isActive = (href: string) => norm(href) === cur;
const menuLabel = isEn ? 'Open menu' : 'Menü öffnen';
const langAriaCurrent = false;
---

<header class="site-header" data-header>
  <div class="container site-header__inner">
    <a class="brand" href={home} aria-label={isEn ? "Frido's Friends e.V. — Home" : "Frido's Friends e.V. — Startseite"}>
      <Logo size={28} color="var(--gold)" />
      <span class="brand__name">Frido&rsquo;s Friends</span>
    </a>

    <nav class="nav" aria-label={isEn ? 'Main navigation' : 'Hauptnavigation'}>
      {nav.map((item) => (
        <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>

    <div class="site-header__actions">
      <a class="lang-toggle" href={altHref} hreflang={isEn ? 'de' : 'en'} aria-label={isEn ? 'Auf Deutsch wechseln' : 'Switch to English'}>{altLabel}</a>
      <a class="btn btn--primary btn--sm" href={joinHref}>{joinLabel}</a>
    </div>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" aria-label={menuLabel} data-nav-toggle>
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div id="mobile-nav" class="mobile-nav" hidden data-mobile-nav>
  <nav aria-label={isEn ? 'Main navigation (mobile)' : 'Hauptnavigation mobil'}>
    {nav.map((item) => (
      <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
    ))}
    <a class="mobile-nav__lang" href={altHref} hreflang={isEn ? 'de' : 'en'} aria-label={isEn ? 'Auf Deutsch wechseln' : 'Switch to English'}>{isEn ? 'Deutsch' : 'English'}</a>
  </nav>
  <a class="btn btn--primary mobile-nav__cta" href={joinHref}>{joinLabel}</a>
</div>

<script>
  // Sticky header border on scroll
  const header = document.querySelector('[data-header]');
  const onScroll = () => header && header.classList.toggle('is-scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Mobile drawer toggle (accessible: aria-expanded + hidden, focus + Escape + scroll lock)
  const toggle = document.querySelector('[data-nav-toggle]');
  const drawer = document.querySelector('[data-mobile-nav]');
  const setOpen = (open: boolean) => {
    if (!toggle || !drawer) return;
    toggle.setAttribute('aria-expanded', String(open));
    if (open) { drawer.removeAttribute('hidden'); } else { drawer.setAttribute('hidden', ''); }
    document.body.style.overflow = open ? 'hidden' : '';
  };
  toggle?.addEventListener('click', () => {
    setOpen(toggle.getAttribute('aria-expanded') !== 'true');
  });
  // close on link click or Escape
  drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
      (toggle as HTMLElement).focus();
    }
  });
  // reset on resize to desktop
  const mq = window.matchMedia('(min-width: 1024px)');
  mq.addEventListener('change', (e) => { if (e.matches) setOpen(false); });
</script>
